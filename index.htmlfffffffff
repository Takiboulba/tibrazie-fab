// HISTORIQUE / ANNULER
// ════════════════════════════════════════════════
function snapshot(){
  const snap=JSON.stringify({steps,cats,statOrder,calState});
  // Couper l'historique au-delà du curseur
  history=history.slice(0,historyPtr+1);
  history.push(snap);
  if(history.length>10)history.shift();
  historyPtr=history.length-1;
  document.getElementById('undo-btn').style.display=historyPtr>0?'':'none';
}
function doUndo(){
  if(historyPtr<=0){alert('Pas d\'historique disponible.');return;}
  historyPtr--;
  const prev=JSON.parse(history[historyPtr]);
  steps=prev.steps; cats=prev.cats; statOrder=prev.statOrder; calState=prev.calState;
  saveLocal(); rebuildCatSelects(); renderAll();
  document.getElementById('undo-btn').style.display=historyPtr>0?'':'none';
  ss('ok','Annulation effectuée');
}

