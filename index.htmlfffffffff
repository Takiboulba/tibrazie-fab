function updateGlobalPbar(){
  const wrap=document.getElementById('global-pbar-wrap');
  if(!wrap)return;
  if(!calState.startDate){wrap.style.opacity='0.4';return;}
  wrap.style.opacity='1';

  const planning=buildPlanning();
  if(!planning||planning.length===0)return;

  const today=new Date();today.setHours(0,0,0,0);
  const startD=getStartDate();
  const endD=dayDate(planning.length-1);

  const hfJours=Object.values(calState.horsForge||{}).filter(function(h){return h.duration==='journée'||h.mins>=DAY_MINS;}).length;
  const totalOuvres=ouvrés(startD,endD)+hfJours;
  const ecoulesOuvres=ouvrés(startD,today);
  const pctTemps=totalOuvres>0?Math.min(100,Math.round(ecoulesOuvres/totalOuvres*100)):0;

  const doneCnt=steps.filter(function(s){return s.done;}).length;
  // Progression basée sur les heures (minutes de référence)
  const totalRefMins=steps.reduce(function(a,s){return a+parseMins(s.ref);},0);
  const doneRefMins=steps.filter(function(s){return s.done;}).reduce(function(a,s){return a+parseMins(s.ref);},0);
  const pctFab=totalRefMins>0?Math.round(doneRefMins/totalRefMins*100):Math.round(doneCnt/steps.length*100);

  const minsParPct=totalRefMins/100;
  const diffPct=pctFab-pctTemps;
  const enAvance=pctFab>=pctTemps;

  const pbar=document.getElementById('global-pbar-done');
  const label=document.getElementById('global-pbar-label');
  const smiley=document.getElementById('global-smiley');
  const smiley2=document.getElementById('global-smiley2');
  const todayBar=document.getElementById('global-pbar-today');
  const dlBar=document.getElementById('global-pbar-deadline');

  if(pbar){pbar.style.width=pctFab+'%';pbar.style.background=enAvance?'#1D9E75':'#E24B4A';}
  if(label)label.textContent=pctFab+'%';

  // Marqueur temps écoulé (orange)
  if(todayBar){
    if(pctTemps>0&&pctTemps<100){todayBar.style.display='block';todayBar.style.left=pctTemps+'%';}
    else{todayBar.style.display='none';}
  }

  // Marqueur deadline (rouge)
  const dlDate=calState.deadlineContract?new Date(calState.deadlineContract+'T00:00:00'):null;
  if(dlBar){
    if(dlDate&&totalOuvres>0){
      const dlOuvres=ouvrés(startD,dlDate);
      const pctDl=Math.min(100,Math.round(dlOuvres/totalOuvres*100));
      dlBar.style.display='block';dlBar.style.left=pctDl+'%';
      if(smiley2){
        if(pctFab>=pctDl){smiley2.style.display='block';smiley2.style.left='calc('+Math.min(92,pctFab)+'% - 9px)';smiley2.textContent='🎉';}
        else{smiley2.style.display='none';}
      }
    }else{dlBar.style.display='none';if(smiley2)smiley2.style.display='none';}
  }

  // Smiley principal
  if(smiley){
    const smileyPos=Math.min(94,Math.max(2,pctFab));
    smiley.style.left='calc('+smileyPos+'% - 11px)';
    smiley.textContent=enAvance?'😊':'😟';
  }
}

