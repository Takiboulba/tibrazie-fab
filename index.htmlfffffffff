// ════════════════════════════════════════════════
// SWIPE NAVIGATION (mobile)
// ════════════════════════════════════════════════
(function(){
  const TABS=['suivi','planning','calendrier','rapports','stock'];
  let swipeStartX=0, swipeStartY=0, swipeStartTime=0;
  const MIN_DIST=60, MAX_TIME=400, MAX_VERT=80;

  function currentTab(){
    return TABS.find(t=>{
      const el=document.getElementById('page-'+t);
      return el&&el.classList.contains('on');
    })||TABS[0];
  }

  document.addEventListener('touchstart',function(e){
    // Ignorer si on touche un input, select, ou élément scrollable interne
    const tag=e.target.tagName;
    if(tag==='INPUT'||tag==='TEXTAREA'||tag==='SELECT')return;
    swipeStartX=e.touches[0].clientX;
    swipeStartY=e.touches[0].clientY;
    swipeStartTime=Date.now();
  },{passive:true});

  document.addEventListener('touchend',function(e){
    if(!swipeStartTime)return;
    const dt=Date.now()-swipeStartTime;
    const dx=e.changedTouches[0].clientX-swipeStartX;
    const dy=e.changedTouches[0].clientY-swipeStartY;
    // Vérifier que c'est bien un swipe horizontal rapide
    if(dt>MAX_TIME||Math.abs(dx)<MIN_DIST||Math.abs(dy)>MAX_VERT)return;
    // Ignorer si on est sur un élément draggable (réorganisation étapes)
    if(e.target.closest('.step-card,.sub-item,.dh'))return;
    const cur=currentTab();
    const idx=TABS.indexOf(cur);
    if(dx<0&&idx<TABS.length-1){
      // Swipe gauche → page suivante
      setTab(TABS[idx+1]);
    }else if(dx>0&&idx>0){
      // Swipe droite → page précédente
      setTab(TABS[idx-1]);
    }
    swipeStartTime=0;
  },{passive:true});
})();

