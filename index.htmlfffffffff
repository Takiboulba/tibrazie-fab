function _initGISClient(){
  const clientId=GCLIENT_ID;
  if(!clientId){
    document.getElementById('btn-glogin').style.display='inline-block';
    ss('off','Client ID manquant');
    return;
  }
  gTokenClient=google.accounts.oauth2.initTokenClient({
    client_id:clientId,
    scope:GSCOPE,
    callback:(resp)=>{
      if(resp.error){ss('err','Erreur auth Google : '+resp.error);return;}
      gToken=resp.access_token;
      localStorage.setItem('g_token_exp',Date.now()+((resp.expires_in||3600)*1000));
      document.getElementById('btn-glogin').style.display='none';
      document.getElementById('btn-glogout').style.display='inline-block';
      startSync();
    }
  });
  // Token encore valide ?
  const exp=parseInt(localStorage.getItem('g_token_exp')||'0');
  if(Date.now()<exp-60000&&localStorage.getItem('g_access_token')){
    gToken=localStorage.getItem('g_access_token');
    document.getElementById('btn-glogin').style.display='none';
    document.getElementById('btn-glogout').style.display='inline-block';
    startSync();
  }else{
    // Demande silencieuse de token (prompt:'none' = pas de popup si déjà autorisé)
    document.getElementById('btn-glogin').style.display='inline-block';
    ss('off','Cliquez sur "Connecter Google Drive"');
    // Tenter connexion silencieuse
    if(gTokenClient)gTokenClient.requestAccessToken({prompt:''});
  }
}

function gLogin(){
  if(gTokenClient)gTokenClient.requestAccessToken({prompt:'consent'});
  else initGIS();
}

function gLogout(){
  if(gToken)google.accounts.oauth2.revoke(gToken,()=>{});
  gToken=null;gFileId=null;
  localStorage.removeItem('g_token_exp');
  localStorage.removeItem('g_access_token');
  document.getElementById('btn-glogin').style.display='inline-block';
  document.getElementById('btn-glogout').style.display='none';
  ss('off','Déconnecté de Google Drive');
  if(syncTimer){clearInterval(syncTimer);syncTimer=null;}
}

// ── API Drive helpers ──
async function driveHeaders(){return{'Authorization':'Bearer '+gToken,'Content-Type':'application/json'};}

async function driveGetFileId(){
  if(gFileId)return gFileId;
  const r=await fetch(
    'https://www.googleapis.com/drive/v3/files?spaces=appDataFolder&q=name%3D%27'+GDRIVE_FILE+'%27&fields=files(id,modifiedTime)',
    {headers:await driveHeaders()}
  );
  if(!r.ok)throw new Error('Drive list: '+r.status);
  const d=await r.json();
  gFileId=(d.files&&d.files.length>0)?d.files[0].id:null;
  return gFileId;
}

async function driveRead(){
  const fid=await driveGetFileId();
  if(!fid)return null;
  const r=await fetch('https://www.googleapis.com/drive/v3/files/'+fid+'?alt=media',{headers:await driveHeaders()});
  if(!r.ok)throw new Error('Drive read: '+r.status);
  return await r.json();
}

async function driveWrite(data){
  const payload=JSON.stringify(data);
  const fid=await driveGetFileId();
  let url,method;
  if(fid){
    // Mise à jour du fichier existant
    url='https://www.googleapis.com/upload/drive/v3/files/'+fid+'?uploadType=media';
    method='PATCH';
  }else{
    // Création du fichier dans appDataFolder
    // On passe d'abord les métadonnées puis le contenu (multipart simplifié en 2 étapes)
    const meta=await fetch('https://www.googleapis.com/drive/v3/files',{
      method:'POST',
      headers:await driveHeaders(),
      body:JSON.stringify({name:GDRIVE_FILE,parents:['appDataFolder']})
    });
    if(!meta.ok)throw new Error('Drive create meta: '+meta.status);
    const md=await meta.json();
    gFileId=md.id;
    url='https://www.googleapis.com/upload/drive/v3/files/'+gFileId+'?uploadType=media';
    method='PATCH';
  }
  const r=await fetch(url,{
    method,
    headers:{'Authorization':'Bearer '+gToken,'Content-Type':'application/json'},
    body:payload
  });
  if(!r.ok)throw new Error('Drive write: '+r.status);
  // Sauvegarder le token pour réutilisation
  localStorage.setItem('g_access_token',gToken);
}

// ── Logique de sync (même logique qu'avant, remplace binGet/binPut) ──
let pendingUpload=false;
function setPending(){pendingUpload=true;localStorage.setItem(STORE+'_pending','1');}
function clearPending(){pendingUpload=false;localStorage.removeItem(STORE+'_pending');}
function hasPending(){return pendingUpload||localStorage.getItem(STORE+'_pending')==='1';}

function applyRemote(r){
  steps=r.steps;
  if(Array.isArray(r.cats)&&r.cats.length>0)cats=r.cats;
  if(Array.isArray(r.statOrder)&&r.statOrder.length>0)statOrder=r.statOrder;
  if(r.calState&&r.calState.days){
    calState=r.calState;
    if(!calState.hfCats)calState.hfCats=[...DEFAULT_HF_CATS];
    if(!calState.stock)calState.stock=JSON.parse(JSON.stringify(DEFAULT_STOCK));
  }
  localStorage.setItem(STORE+'_ts',r.ts);
  saveLocal();rebuildCatSelects();renderAll();
}

async function startSync(){
  if(!gToken){ss('off','Non connecté à Google Drive');return;}
  if(isSyncing)return;
  isSyncing=true;ss('spin','Connexion Drive...');
  try{
    const r=await driveRead();
    const rTs=r&&r.ts?r.ts:0;
    const lTs=parseInt(localStorage.getItem(STORE+'_ts')||'0');
    const rSteps=r&&Array.isArray(r.steps)?r.steps:[];

    if(rSteps.length===0){
      const ts=Date.now();
      await driveWrite({steps,cats,statOrder,calState,ts});
      localStorage.setItem(STORE+'_ts',ts);clearPending();
      ss('ok','Drive ✓ — données initiales envoyées');
    }else if(hasPending()||lTs>=rTs){
      const ts=Date.now();
      await driveWrite({steps,cats,statOrder,calState,ts});
      localStorage.setItem(STORE+'_ts',ts);clearPending();
      ss('ok','Drive ✓ sauvegardé');
    }else{
      applyRemote(r);
      ss('ok','Drive ✓ — mis à jour '+new Date().toLocaleTimeString('fr-FR'));
    }
    if(syncTimer)clearInterval(syncTimer);
    syncTimer=setInterval(pollSync,20000);
  }catch(e){
    console.error('Drive sync error:',e);
    if(e.message&&e.message.includes('401')){
      // Token expiré → redemander
      gToken=null;
      document.getElementById('btn-glogin').style.display='inline-block';
      ss('err','Session expirée — reconnectez Drive');
    }else{
      ss('err','Hors ligne — données locales actives');
    }
  }
  isSyncing=false;
}

async function pollSync(){
  if(!gToken||isSyncing)return;
  try{
    if(hasPending()){
      isSyncing=true;
      const ts=Date.now();
      await driveWrite({steps,cats,statOrder,calState,ts});
      localStorage.setItem(STORE+'_ts',ts);clearPending();
      isSyncing=false;
      ss('ok','Drive ✓ sync différée — '+new Date().toLocaleTimeString('fr-FR'));
      return;
    }
    const r=await driveRead();
    if(!r||!Array.isArray(r.steps)||r.steps.length===0)return;
    const lTs=parseInt(localStorage.getItem(STORE+'_ts')||'0');
    if(r.ts>lTs+2000&&!hasPending()){
      applyRemote(r);
      ss('ok','Drive ✓ mis à jour — '+new Date().toLocaleTimeString('fr-FR'));
    }else{
      ss('ok','Drive ✓ '+new Date().toLocaleTimeString('fr-FR'));
    }
  }catch(e){ss('err','Hors ligne...');}
}

function save(){
  snapshot();
  saveLocal();
  (async()=>{
    if(!gToken){setPending();return;}
    if(isSyncing){setPending();return;}
    try{
      const ts=Date.now();
      await driveWrite({steps,cats,statOrder,calState,ts});
      localStorage.setItem(STORE+'_ts',ts);
      clearPending();
      ss('ok','Drive ✓ '+new Date().toLocaleTimeString('fr-FR'));
    }catch(e){
      setPending();
      ss('err','Hors ligne — modif. en attente 📶');
    }
  })();
}

