<title>Tibrazié – Fabrication</title>
<script>
// Logo Tibrazié : flamme + cercle + T, fond sombre pour icône app
(function(){
  const svg=`<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512'>
    <!-- Fond arrondi sombre style iOS -->
    <rect width='512' height='512' rx='115' fill='#1a1a1a'/>
    <!-- ===== FLAMME ===== -->
    <!-- Corps principal de la flamme (drop shape + flammes) en blanc/vert dégradé -->
    <g transform='translate(256,252)' fill='#1D9E75'>
      <!-- Flamme principale : forme goutte pointue vers le haut -->
      <path d='
        M0,-195
        C8,-165 38,-140 52,-108
        C72,-60 68,-10 62,20
        C88,0 95,-30 88,-68
        C110,-40 115,0 108,38
        C138,-10 140,-60 125,-105
        C148,-70 155,-20 148,25
        C162,-30 158,-95 130,-140
        C148,-118 152,-85 145,-60
        C135,-100 110,-130 95,-165
        C80,-130 75,-90 82,-55
        C65,-90 60,-135 72,-170
        C45,-145 20,-118 8,-85
        C-5,-118 -30,-145 -57,-170
        C-45,-135 -40,-90 -57,-55
        C-50,-90 -55,-130 -70,-165
        C-85,-130 -110,-100 -120,-60
        C-127,-85 -123,-118 -105,-140
        C-133,-95 -137,-30 -123,25
        C-130,-20 -123,-70 -103,-105
        C-110,0 -107,-40 -83,-68
        C-90,-30 -87,0 -57,20
        C-63,-10 -67,-60 -47,-108
        C-33,-140 -3,-165 0,-195
        Z
      '/>
      <!-- Petite flamme gauche -->
      <path d='M-95,-62 C-115,-90 -112,-125 -95,-148 C-78,-125 -75,-90 -95,-62 Z' opacity='0.7'/>
      <!-- Petite flamme droite -->
      <path d='M95,-62 C115,-90 112,-125 95,-148 C78,-125 75,-90 95,-62 Z' opacity='0.7'/>
    </g>
    <!-- ===== CERCLE OUVERT (anneau) ===== -->
    <!-- Fond du cercle = fond appli pour simuler le trou -->
    <circle cx='256' cy='308' r='88' fill='#1a1a1a'/>
    <!-- Anneau vert -->
    <circle cx='256' cy='308' r='88' fill='none' stroke='#1D9E75' stroke-width='28'/>
    <!-- Masque bas de la flamme pour que le cercle la coupe -->
    <!-- La flamme passe derrière le bas du cercle : on redessine le bas du cercle par-dessus -->
    <path d='M168,308 Q168,396 256,396 Q344,396 344,308' fill='#1a1a1a'/>
    <path d='M168,308 Q168,396 256,396 Q344,396 344,308' fill='none' stroke='#1D9E75' stroke-width='28'/>
    <!-- ===== LETTRE T ===== -->
    <text x='256' y='334' text-anchor='middle' dominant-baseline='middle'
      font-family='Arial Black,Arial,sans-serif' font-weight='900'
      font-size='110' fill='#ffffff' letter-spacing='-2'>T</text>
    <!-- ===== TEXTE Tibrazié ===== -->
    <text x='256' y='448' text-anchor='middle'
      font-family='Arial Black,Arial,sans-serif' font-weight='900'
      font-size='52' fill='#5DCAA5' letter-spacing='1'>Tibrazié</text>
  </svg>`;
  const b64=btoa(unescape(encodeURIComponent(svg)));
  const url='data:image/svg+xml;base64,'+b64;
  let lk=document.createElement('link');lk.rel='icon';lk.type='image/svg+xml';lk.href=url;document.head.appendChild(lk);
  let at=document.createElement('link');at.rel='apple-touch-icon';at.href=url;document.head.appendChild(at);
})();
</script>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
html,body{background:#1a1a1a;color:#e8e8e8;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;min-height:100vh;-webkit-text-size-adjust:100%;}
button,input,select,textarea{font-family:inherit;-webkit-appearance:none;-webkit-tap-highlight-color:transparent;touch-action:manipulation;}
input[type=color]{-webkit-appearance:none;border-radius:7px;}
select{border-radius:8px;}
input:focus,textarea:focus,select:focus{outline:none;border-color:#1D9E75!important;}

.sync-bar{background:#0a1520;border-bottom:1px solid #1a3050;padding:5px 12px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.sync-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.sync-dot.ok{background:#1D9E75;}.sync-dot.off{background:#555;}.sync-dot.err{background:#E24B4A;}.sync-dot.spin{background:#BA7517;animation:blink 1s infinite;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:.3;}}
.sync-txt{font-size:11px;color:#777;flex:1;}
.undo-btn{font-size:11px;height:24px;padding:0 9px;border:1px solid #444;border-radius:6px;background:#2a2a2a;color:#EF9F27;cursor:pointer;white-space:nowrap;}
.undo-btn:hover{background:#3a2a00;}

/* ── STOCK ── */
.stock-tr{border-bottom:1px solid #2a2a2a;transition:background .15s;cursor:default;}
.stock-tr:hover{background:#1a1a1a;}
.stock-tr.dragging{opacity:0.4;}
.stock-tr.drag-over-top{box-shadow:inset 0 2px 0 #1D9E75;}
.stock-tr.drag-over-bot{box-shadow:inset 0 -2px 0 #1D9E75;}
.stock-drag-handle{cursor:grab;color:#444;padding:0 6px;font-size:14px;user-select:none;}
.stock-drag-handle:active{cursor:grabbing;}
.stock-td{padding:6px 6px;vertical-align:middle;}
.stock-inp{background:#1e1e1e;border:1px solid #333;border-radius:6px;color:#e8e8e8;font-size:12px;padding:3px 7px;width:100%;text-align:center;}
.stock-inp-name{text-align:left;}
.stock-inp:focus{border-color:#1D9E75;outline:none;}
.stock-badge{display:inline-block;padding:2px 8px;border-radius:99px;font-size:10px;font-weight:700;}
.stock-ok{background:#0d2a1e;color:#5DCAA5;border:1px solid #1D9E75;}
.stock-warn{background:#2a1a00;color:#EF9F27;border:1px solid #EF9F27;}
.stock-danger{background:#2a1010;color:#F0997B;border:1px solid #E24B4A;}
.stock-del-btn{background:none;border:1px solid #3a2020;border-radius:6px;color:#666;cursor:pointer;padding:3px 7px;font-size:11px;}
.stock-del-btn:hover{border-color:#E24B4A;color:#F0997B;}
/* Alert rows */
.alert-row{display:flex;align-items:center;gap:7px;background:#1a0a0a;border:1px solid #3a1a1a;border-radius:8px;padding:6px 9px;font-size:12px;flex-wrap:wrap;}
.alert-row.ordered{background:#0a1a2a;border-color:#1a4a6a;}
.alert-btn{border:none;border-radius:6px;cursor:pointer;font-size:11px;padding:3px 9px;font-weight:600;}
.alert-btn-order{background:#1a2a3a;color:#7ab8e8;border:1px solid #2a5a8a;}
.alert-btn-order:hover{background:#1D9E75;color:#fff;border-color:#1D9E75;}
.alert-btn-recv{background:#0d2a1e;color:#5DCAA5;border:1px solid #1D9E75;}
.alert-btn-recv:hover{background:#1D9E75;color:#fff;}
.alert-btn-del{background:none;border:1px solid #3a1a1a;color:#555;padding:3px 7px;border-radius:6px;cursor:pointer;font-size:11px;}
.alert-btn-del:hover{border-color:#E24B4A;color:#F0997B;}
.global-pbar-wrap{position:sticky;top:0;z-index:49;background:#111;padding:5px 10px;border-bottom:1px solid #2a2a2a;}

.main-tabs{display:flex;background:#1e1e1e;border-bottom:2px solid #2a2a2a;position:sticky;top:32px;z-index:50;}
.mtab{flex:1;height:44px;font-size:13px;font-weight:600;border:none;background:none;color:#666;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;transition:all .2s;}
.mtab.on{color:#1D9E75;border-bottom-color:#1D9E75;background:#111;}

.btn{height:32px;padding:0 12px;font-size:12px;font-weight:500;border-radius:8px;cursor:pointer;white-space:nowrap;border:1.5px solid #666;background:#333;color:#e8e8e8;}
.btn:hover{background:#444;}
.btn-g{background:#0F6E56;border-color:#1D9E75;color:#fff;}.btn-g:hover{background:#1D9E75;}
.btn-o{background:#7a3f00;border-color:#c47a1a;color:#f0c070;}.btn-o:hover{background:#9a5500;}
.btn-r{background:#5a1515;border-color:#a33030;color:#f09090;}.btn-r:hover{background:#7a2020;}
.btn-b{background:#0a3460;border-color:#2060a0;color:#80b8f0;}.btn-b:hover{background:#0f4080;}
.btn-p{background:#2a1a3a;border-color:#7a50c0;color:#c090f0;}.btn-p:hover{background:#3a2050;}

.page{display:none;padding-bottom:20px;}
.page.on{display:block;}

/* ─── SUIVI ─── */
.hdr{background:#222;border:1px solid #444;border-radius:12px;padding:13px 14px;margin:10px 10px 8px;}
.hdr-title{font-size:16px;font-weight:700;color:#e8e8e8;margin-bottom:8px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:4px;}
.hdr-hint{font-size:10px;font-weight:400;color:#666;}
.pbar-bg{background:#2a2a2a;border-radius:99px;height:10px;width:100%;overflow:hidden;border:1px solid #444;margin-bottom:8px;}
.pbar-fill{height:100%;background:#1D9E75;border-radius:99px;transition:width .5s;}
.stat-hint{font-size:10px;color:#555;text-align:center;padding:2px 0 5px;}
.stat-area{display:flex;flex-wrap:wrap;gap:5px;}
.stat-card{background:#2a2a2a;border:1px solid #444;border-radius:8px;padding:7px 9px;cursor:grab;user-select:none;min-width:88px;flex:1;}
.stat-card.dragging{opacity:.3;}.stat-card.drag-over{border-color:#1D9E75;border-width:2px;}.stat-card.accent{background:#0d2018;border:1.5px solid #1D9E75;}
.stat-l{font-size:10px;color:#888;}.stat-v{font-size:16px;font-weight:700;color:#e8e8e8;margin-top:2px;}.stat-v.green{color:#1D9E75;}.stat-sub{font-size:10px;color:#666;margin-top:1px;}

.toolbar{display:flex;gap:6px;margin:0 10px 8px;flex-wrap:wrap;align-items:center;}
.toolbar input[type=text]{flex:1;min-width:110px;height:32px;font-size:13px;padding:0 9px;border:1px solid #555;border-radius:8px;background:#2a2a2a;color:#e8e8e8;}
.toolbar select{height:32px;font-size:13px;padding:0 9px;border:1.5px solid #666;border-radius:8px;background:#333;color:#e8e8e8;font-weight:500;cursor:pointer;}
.toolbar select:hover{background:#444;border-color:#888;}
.search-bar select{height:34px;font-size:13px;padding:0 9px;border:1.5px solid #666;border-radius:8px;background:#333;color:#e8e8e8;font-weight:500;cursor:pointer;}
.search-bar select:hover{background:#444;border-color:#888;}
.search-bar{display:flex;gap:6px;margin:0 10px 8px;align-items:center;}
.search-bar input{flex:1;height:34px;font-size:13px;padding:0 10px 0 34px;border:1px solid #555;border-radius:8px;background:#2a2a2a;color:#e8e8e8;}
.search-wrap{position:relative;flex:1;}
.search-ico{position:absolute;left:10px;top:50%;transform:translateY(-50%);font-size:14px;color:#555;pointer-events:none;}
.sort-bar{display:flex;gap:5px;margin:0 10px 8px;flex-wrap:wrap;align-items:center;}
.sort-lbl{font-size:11px;color:#666;flex-shrink:0;}
.sb{height:27px;padding:0 9px;font-size:11px;font-weight:500;border-radius:7px;cursor:pointer;border:1px solid #444;background:#2a2a2a;color:#888;white-space:nowrap;}
.sb:hover{background:#333;color:#ccc;}.sb.on{background:#1a3020;border-color:#1D9E75;color:#5DCAA5;}
.confirm-box{display:none;background:#1e0808;border:1px solid #6a2020;border-radius:9px;padding:9px 12px;margin:0 10px 8px;flex-wrap:wrap;gap:8px;align-items:center;}
.confirm-box.open{display:flex;}
.confirm-txt{font-size:13px;color:#f09090;flex:1;}
.cat-grp-hdr{display:flex;align-items:center;gap:8px;padding:10px 4px 4px;}
.cat-grp-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;}.cat-grp-name{font-size:12px;font-weight:700;}.cat-grp-count{font-size:11px;color:#666;}.cat-grp-line{flex:1;height:1px;background:#2a2a2a;}
.step-card{background:#222;border:1px solid #3a3a3a;border-radius:9px;margin-bottom:5px;overflow:hidden;transition:box-shadow .15s,opacity .15s,transform .1s;}
.step-main{display:flex;align-items:center;gap:6px;padding:7px 9px;}
.step-card.done{opacity:.55;}.step-card.done .sname{text-decoration:line-through;color:#666;}
.step-card.dragging{opacity:.18;transform:scale(0.98);}
.step-card.drag-over-top{box-shadow:0 -3px 0 #1D9E75,0 0 0 1px #1D9E7555;border-color:#1D9E7555;}
.step-card.drag-over-bot{box-shadow:0 3px 0 #1D9E75,0 0 0 1px #1D9E7555;border-color:#1D9E7555;}
.dh{font-size:13px;color:#555;flex-shrink:0;user-select:none;cursor:grab;transition:color .1s;}
.dh:hover{color:#1D9E75;}
.snum{font-size:11px;color:#555;min-width:20px;text-align:right;flex-shrink:0;}
.chk{width:19px;height:19px;border-radius:5px;border:1.5px solid #555;display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;background:#2a2a2a;transition:background .15s,border-color .15s,transform .1s;}
.chk:active{transform:scale(0.88);}
.chk.on{background:#1D9E75;border-color:#0F6E56;}.chk svg{display:none;}.chk.on svg{display:block;}
.sname{font-size:13px;color:#e0e0e0;flex:1;line-height:1.35;min-width:0;}
.tbadges{display:flex;gap:3px;flex-shrink:0;flex-wrap:wrap;}
.tb{font-size:10px;padding:2px 6px;border-radius:5px;white-space:nowrap;font-weight:500;}
.tb-r{background:#1a2a1a;color:#5DCAA5;border:1px solid #1D9E7440;}
.tb-s{background:#1a1f30;color:#85B7EB;border:1px solid #185FA540;cursor:pointer;}.tb-s.has{background:#1a2538;border-color:#185FA5;}
.cat-b{font-size:10px;font-weight:500;padding:2px 6px;border-radius:99px;flex-shrink:0;cursor:pointer;border:1px solid transparent;}
.ib{background:none;border:none;cursor:pointer;font-size:12px;color:#777;padding:0 2px;flex-shrink:0;}.ib:hover{color:#ccc;}.ib.del:hover{color:#E24B4A;}
.step-det{border-top:1px solid #2a2a2a;padding:10px 12px;display:none;flex-direction:column;gap:8px;background:#1c1c1c;}
.step-det.open{display:flex;}
.dl{font-size:11px;color:#888;min-width:78px;}.dr{display:flex;gap:7px;flex-wrap:wrap;align-items:center;}
.di{height:28px;font-size:12px;padding:0 8px;border:1px solid #444;border-radius:7px;background:#2a2a2a;color:#e8e8e8;flex:1;min-width:80px;}
.tr2{display:flex;gap:7px;flex-wrap:wrap;}.tbox{flex:1;min-width:120px;}
.tbox label{font-size:11px;color:#888;display:block;margin-bottom:3px;}
.tbox input{width:100%;height:29px;font-size:12px;padding:0 8px;border:1px solid #444;border-radius:7px;background:#2a2a2a;color:#e8e8e8;}
textarea.di{height:auto;padding:5px 8px;resize:vertical;}
.sub-lbl{font-size:11px;font-weight:500;color:#777;display:block;margin-bottom:4px;}
.sub-item{display:flex;align-items:flex-start;gap:6px;margin-bottom:4px;padding:5px 7px;background:#242424;border:1px solid #333;border-radius:7px;transition:opacity .12s,box-shadow .12s,transform .1s;}
.sub-item.sub-dragging{opacity:0.25;transform:scale(0.97);}
.sub-item.sub-drag-over-top{box-shadow:0 -2px 0 #1D9E75,0 0 6px #1D9E7530;border-color:#1D9E7555;}
.sub-item.sub-drag-over-bot{box-shadow:0 2px 0 #1D9E75,0 0 6px #1D9E7530;border-color:#1D9E7555;}
.sub-drag-handle{cursor:grab;color:#444;font-size:13px;user-select:none;flex-shrink:0;padding:1px 2px;margin-top:1px;line-height:1;transition:color .1s;}
.sub-drag-handle:hover{color:#1D9E75;}
.sub-drag-handle:active{cursor:grabbing;}
.sub-chk{width:15px;height:15px;border-radius:3px;border:1.5px solid #555;display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;margin-top:1px;background:#2a2a2a;}
.sub-chk.on{background:#1D9E75;border-color:#0F6E56;}.sub-chk svg{display:none;}.sub-chk.on svg{display:block;}
.sub-txt{font-size:12px;color:#e0e0e0;flex:1;line-height:1.4;}.sub-txt.done{text-decoration:line-through;color:#666;}
.sub-del{background:none;border:none;cursor:pointer;font-size:11px;color:#555;padding:0;}.sub-del:hover{color:#E24B4A;}
.sub-times{display:flex;gap:4px;margin-top:3px;flex-wrap:wrap;}
.sub-tb{font-size:10px;padding:1px 5px;border-radius:5px;font-weight:500;cursor:pointer;}
.sub-tb-r{background:#1a2a1a;color:#5DCAA5;border:1px solid #1D9E7440;}
.sub-tb-s{background:#1a1f30;color:#85B7EB;border:1px solid #185FA540;}.sub-tb-s.has{background:#1a2538;border-color:#185FA5;}
.sub-add{display:flex;gap:5px;margin-top:4px;}
.sub-add input{flex:1;height:27px;font-size:12px;padding:0 8px;border:1px solid #444;border-radius:7px;background:#2a2a2a;color:#e8e8e8;}
/* ─── TEMPS POST-FAB ─── */
.postfab-section{margin:8px 10px 0;background:#1e1a2e;border:1px solid #5a3a8a;border-radius:12px;overflow:hidden;}
.postfab-header{display:flex;align-items:center;gap:8px;padding:11px 13px;border-bottom:1px solid #3a2a5a;flex-wrap:wrap;}
.postfab-title-input{background:none;border:none;font-size:14px;font-weight:700;color:#c090f0;flex:1;min-width:120px;cursor:text;padding:0;}
.postfab-title-input:focus{outline:1px dashed #7a50c0;border-radius:4px;}
.postfab-cat-section{padding:8px 13px 0;}
.postfab-cat-hdr{display:flex;align-items:center;gap:6px;padding:6px 0 3px;}
.postfab-item{display:flex;align-items:center;gap:6px;padding:5px 7px;background:#231a35;border:1px solid #3a2a5a;border-radius:7px;margin-bottom:4px;}
