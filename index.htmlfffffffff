    el.innerHTML=`<div class="stat-l">⠿ ${def.label}</div><div class="stat-v${def.accent?' green':''}">${v}</div>${sub?`<div class="stat-sub">${sub}</div>`:''}`;
    el.addEventListener('dragstart',e=>{statDragSrc=id;el.classList.add('dragging');e.dataTransfer.effectAllowed='move';e.stopPropagation();});
    el.addEventListener('dragend',()=>{el.classList.remove('dragging');g.querySelectorAll('.stat-card').forEach(x=>x.classList.remove('drag-over'));});
