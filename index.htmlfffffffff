// DRAG & DROP TACTILE (mobile)
// ════════════════════════════════════════════════
(function(){
  let touchDragEl=null,touchDragId=null,touchClone=null,touchOffX=0,touchOffY=0;
  let touchLongPress=null;

  function cleanTouchDrag(){
    if(touchClone&&touchClone.parentNode)touchClone.parentNode.removeChild(touchClone);
    touchClone=null;touchDragEl=null;touchDragId=null;
    document.querySelectorAll('.step-card').forEach(function(x){x.classList.remove('drag-over-top','drag-over-bot','dragging');});
  }

  function getCardUnderTouch(x,y){
    if(touchClone)touchClone.style.display='none';
    const el=document.elementFromPoint(x,y);
    if(touchClone)touchClone.style.display='';
    if(!el)return null;
    return el.closest('.step-card');
  }

  document.addEventListener('touchstart',function(e){
    if(currentSort!=='ordre')return;
    const handle=e.target.closest('.dh');
    if(!handle)return;
    const card=handle.closest('.step-card');
    if(!card)return;
    touchLongPress=setTimeout(function(){
      touchLongPress=null;
      touchDragEl=card;
      touchDragId=parseInt(card.dataset.id);
      const r=card.getBoundingClientRect();
      const t=e.touches[0];
      touchOffX=t.clientX-r.left;touchOffY=t.clientY-r.top;
      touchClone=card.cloneNode(true);
      touchClone.style.cssText='position:fixed;z-index:9999;width:'+r.width+'px;opacity:0.85;pointer-events:none;left:'+(t.clientX-touchOffX)+'px;top:'+(t.clientY-touchOffY)+'px;box-shadow:0 8px 24px #0008;transform:scale(1.03);';
      document.body.appendChild(touchClone);
      card.classList.add('dragging');
      // Vibration feedback
      if(navigator.vibrate)navigator.vibrate(40);
    },350);
  },{passive:true});

  document.addEventListener('touchmove',function(e){
    if(touchLongPress){clearTimeout(touchLongPress);touchLongPress=null;}
    if(!touchDragEl||!touchClone)return;
    e.preventDefault();
    const t=e.touches[0];
    touchClone.style.left=(t.clientX-touchOffX)+'px';
    touchClone.style.top=(t.clientY-touchOffY)+'px';
    // Highlight target
    document.querySelectorAll('.step-card').forEach(function(x){x.classList.remove('drag-over-top','drag-over-bot');});
    const target=getCardUnderTouch(t.clientX,t.clientY);
    if(target&&target!==touchDragEl){
      const rect=target.getBoundingClientRect();
      if(t.clientY<rect.top+rect.height/2)target.classList.add('drag-over-top');
      else target.classList.add('drag-over-bot');
    }
  },{passive:false});

  document.addEventListener('touchend',function(e){
    if(touchLongPress){clearTimeout(touchLongPress);touchLongPress=null;}
    if(!touchDragEl||!touchClone)return;
    const t=e.changedTouches[0];
    const target=getCardUnderTouch(t.clientX,t.clientY);
    if(target&&target!==touchDragEl){
      const toId=parseInt(target.dataset.id);
      const rect=target.getBoundingClientRect();
      const after=t.clientY>=rect.top+rect.height/2;
      const si=steps.findIndex(x=>x.id===touchDragId);
      const ti=steps.findIndex(x=>x.id===toId);
      if(si>=0&&ti>=0&&si!==ti){
        const[m]=steps.splice(si,1);
        const newTi=steps.findIndex(x=>x.id===toId);
        steps.splice(after?newTi+1:newTi,0,m);
        save();renderSuivi();
      }
    }
    cleanTouchDrag();
  },{passive:true});

  document.addEventListener('touchcancel',function(){
    if(touchLongPress){clearTimeout(touchLongPress);touchLongPress=null;}
    cleanTouchDrag();
  },{passive:true});
})();

