  });
}
function renderTotals(){
  let tR=0,nR=0,tS=0,nS=0;
  steps.forEach(s=>{const r=parseMins(s.ref),sp=parseMins(s.spent);if(r){tR+=r;nR++;}if(sp){tS+=sp;nS++;}});
  document.getElementById('tot-ref').textContent=nR?fmtMins(tR):'—';
  document.getElementById('tot-spent').textContent=nS?fmtMins(tS):'—';
  if(nR&&nS){const d=tS-tR,el=document.getElementById('tot-diff');el.textContent=(d>=0?'+':'')+fmtMins(Math.abs(d));el.style.color=d>0?'#F0997B':d<0?'#5DCAA5':'#e8e8e8';}
  else document.getElementById('tot-diff').textContent='—';
}
function setSort(s){
  if(s==='categorie'){
    if(currentSort!=='categorie'){currentSort='categorie';catCycleIdx=-1;}
    else{catCycleIdx=(catCycleIdx+1)%(cats.length+1);if(catCycleIdx===cats.length)catCycleIdx=-1;}
    document.getElementById('sb-categorie').textContent=catCycleIdx===-1?'Catégorie':'📂 '+cats[catCycleIdx].name;
  }else{
    currentSort=s;catCycleIdx=-1;
    document.getElementById('sb-categorie').textContent='Catégorie';
  }
  document.querySelectorAll('.sb').forEach(b=>b.classList.remove('on'));
  const el=document.getElementById('sb-'+s);if(el)el.classList.add('on');
  renderSuivi();
}
function getSorted(list){
  let arr=[...list];
  if(currentSort==='categorie'&&catCycleIdx>=0)arr=arr.filter(s=>s.cat===cats[catCycleIdx].id);
  switch(currentSort){
    case'categorie':return arr.sort((a,b)=>{const ca=cats.findIndex(c=>c.id===a.cat),cb=cats.findIndex(c=>c.id===b.cat);return ca-cb||a.name.localeCompare(b.name,'fr');});
    case'ref-asc':return arr.sort((a,b)=>(parseMins(a.ref)||9999)-(parseMins(b.ref)||9999));
    case'ref-desc':return arr.sort((a,b)=>(parseMins(b.ref)||0)-(parseMins(a.ref)||0));
    case'alpha':return arr.sort((a,b)=>a.name.localeCompare(b.name,'fr'));
    case'todo':return arr.sort((a,b)=>Number(a.done)-Number(b.done));
    default:return arr;
  }
}
