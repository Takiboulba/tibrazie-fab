function renderPlanProgress(planning){
  const box=document.getElementById('plan-progress');
  if(!calState.startDate){box.style.display='none';return;}
  box.style.display='block';

  const today=new Date();today.setHours(0,0,0,0);
  const startD=getStartDate();
  const endD=dayDate(planning.length-1);
  const endDTheoLocal=endD;

  const hfJours=Object.values(calState.horsForge||{}).filter(function(h){return h.duration==='journée'||h.mins>=DAY_MINS;}).length;
  const totalOuvres=ouvrés(startD,endD)+hfJours; // endD = fin théorique
  const ecoulesOuvres=ouvrés(startD,today);
  const pctTemps=totalOuvres>0?Math.min(100,Math.round(ecoulesOuvres/totalOuvres*100)):0;

  const doneCnt=steps.filter(function(s){return s.done;}).length;
  // Progression basée sur les heures (minutes de référence cochées)
  const totalRefMins=steps.reduce(function(a,s){return a+parseMins(s.ref);},0);
  const doneRefMins=steps.filter(function(s){return s.done;}).reduce(function(a,s){return a+parseMins(s.ref);},0);
  const pctFab=totalRefMins>0?Math.round(doneRefMins/totalRefMins*100):Math.round(doneCnt/steps.length*100);

  // Calcul heures d'avance ou retard
  const minsParPct=totalRefMins/100;
  const diffPct=pctFab-pctTemps;
  const diffMins=Math.abs(Math.round(diffPct*minsParPct));
  const diffStr=fmtMins(diffMins);

  const enAvance=pctFab>=pctTemps;
  const pbar=document.getElementById('plan-pbar-done');
  const label=document.getElementById('plan-pbar-label');
  const smiley=document.getElementById('plan-smiley');
  const smiley2=document.getElementById('plan-smiley2');
  const todayBar=document.getElementById('plan-pbar-today');
  const dlBar=document.getElementById('plan-pbar-deadline');
  const info=document.getElementById('plan-pbar-info');
  const statusTxt=document.getElementById('plan-status-txt');

  pbar.style.width=pctFab+'%';
  pbar.style.background=enAvance?'#1D9E75':'#E24B4A';
  label.textContent=pctFab+'%';

  // Marqueur aujourd'hui
  if(pctTemps>0&&pctTemps<100){todayBar.style.display='block';todayBar.style.left=pctTemps+'%';}
  else{todayBar.style.display='none';}

  // Marqueur deadline contractuelle
  const dlDate=calState.deadlineContract?new Date(calState.deadlineContract+'T00:00:00'):null;
  if(dlDate&&totalOuvres>0){
    const dlOuvres=ouvrés(startD,dlDate);
    const pctDl=Math.min(100,Math.round(dlOuvres/totalOuvres*100));
    dlBar.style.display='block';
    dlBar.style.left=pctDl+'%';
    // Smiley chapeau si on dépasse la deadline
    if(pctFab>=pctDl){
      smiley2.style.display='block';
      smiley2.style.left='calc('+Math.min(92,pctFab)+'% - 9px)';
      smiley2.textContent='🎉';
    }else{smiley2.style.display='none';}
  }else{dlBar.style.display='none';smiley2.style.display='none';}

  const smileyPos=Math.min(94,Math.max(2,pctFab));
  smiley.style.left='calc('+smileyPos+'% - 11px)';
  smiley.textContent=enAvance?'😊':'😟';

  if(enAvance){
    statusTxt.textContent='✓ En avance : +'+diffStr+' ('+Math.abs(diffPct)+'%)';
    statusTxt.style.color='#1D9E75';
  }else{
    statusTxt.textContent='⚠ Retard : -'+diffStr+' (-'+Math.abs(diffPct)+'%)';
    statusTxt.style.color='#E24B4A';
  }

  const joursRestants=Math.max(0,totalOuvres-ecoulesOuvres);
  const stepsRestantes=steps.length-doneCnt;
  const heuresRestantes=steps.filter(function(s){return !s.done;}).reduce(function(a,s){return a+parseMins(s.ref);},0);
  const finPrevue=endD?endD.toLocaleDateString('fr-FR',{day:'numeric',month:'short',year:'numeric'}):'?';
  info.innerHTML='<span>📅 Fin calculée : '+finPrevue+'</span>'
    +(calState.deadlineContract?'<span style="color:#F0997B">🚩 Deadline : '+new Date(calState.deadlineContract+'T00:00:00').toLocaleDateString('fr-FR',{day:'numeric',month:'short'})+'</span>':'')
    +'<span>🏗 '+stepsRestantes+' étape'+(stepsRestantes>1?'s':'')+' restante'+(stepsRestantes>1?'s':'')+' ('+fmtMins(heuresRestantes)+')</span>'
    +'<span>📆 '+joursRestants+' jour'+(joursRestants>1?'s':'')+' ouvré'+(joursRestants>1?'s':'')+' restant'+(joursRestants>1?'s':'')+'</span>'
    +'<span style="color:#EF9F27">🕐 Temps écoulé : '+pctTemps+'%</span>';
}

