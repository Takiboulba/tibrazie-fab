// CALENDRIER ANNUEL
// ════════════════════════════════════════════════
let calViewYear=new Date().getFullYear();
let calViewMonth=new Date().getMonth();

function saveCalConfig(){
  const dlf=document.getElementById('dl-first');
  const dlp=document.getElementById('dl-period');
  if(dlf)calState.dlFirst=dlf.value||'2026-04-30';
  if(dlp)calState.dlPeriod=parseInt(dlp.value)||6;
  save();renderCalendrier();renderPlanning();
}

// Générer toutes les deadlines contractuelles (toutes les N semaines depuis la 1ère)
function getDeadlines(yearFrom, yearTo){
  const first=new Date((calState.dlFirst||'2026-04-30')+'T00:00:00');
  const periodDays=(calState.dlPeriod||6)*7;
  const deadlines=[];
  let d=new Date(first);
  // Aller en arrière si besoin
  while(d.getFullYear()>yearFrom) d=new Date(d.getTime()-periodDays*86400000);
  // Avancer jusqu'à couvrir la plage
  while(d.getFullYear()<=yearTo+1){
    if(d.getFullYear()>=yearFrom) deadlines.push(new Date(d));
    d=new Date(d.getTime()+periodDays*86400000);
  }
  return deadlines;
}

function saveDeadlines(){saveCalConfig();}

function calGoToday(){calViewYear=new Date().getFullYear();renderCalendrier();}
function calPrevYear(){calViewYear--;renderCalendrier();}
function calNextYear(){calViewYear++;renderCalendrier();}
function calPrevMonth(){calViewMonth--;if(calViewMonth<0){calViewMonth=11;calViewYear--;}renderCalendrier();}
function calNextMonth(){calViewMonth++;if(calViewMonth>11){calViewMonth=0;calViewYear++;}renderCalendrier();}

function renderCalendrier(){
  const lbl=document.getElementById('cal-year-lbl');
  const annuel=document.getElementById('cal-annuel');
  const ecartBox=document.getElementById('cal-ecart-box');
  if(!lbl||!annuel)return;

  // Init config
  if(document.getElementById('dl-first')&&calState.dlFirst)
    document.getElementById('dl-first').value=calState.dlFirst;
  if(document.getElementById('dl-period')&&calState.dlPeriod)
    document.getElementById('dl-period').value=calState.dlPeriod;

  lbl.textContent=calViewYear;

  const planning=buildPlanning(); // planning complet pour la vue
  const startD=calState.startDate?getStartDate():null;
  // Fin théorique = date début + total jours (toutes étapes)
  const endDTheo=startD&&planning.length>0?dayDate(planning.length-1):null;
  // Fin prévue réelle = aujourd'hui + jours restants (étapes non cochées)
  const endDReel=getFinalDatePrevue();

  // Deadlines contractuelles
  const deadlines=getDeadlines(calViewYear-1,calViewYear+1);
  const dlDates=new Set(deadlines.map(function(d){return d.toISOString().slice(0,10);}));

  // Prochaine deadline (ou la dernière passée si en retard)
  const today=new Date();today.setHours(0,0,0,0);
  // La deadline "active" = la plus proche passée OU présente non encore terminée
  // Si on a fini la fab (toutes étapes cochées), on prend la prochaine à venir
  // Si on n'a pas fini (étapes restantes), on prend la deadline que l'on devait respecter (la plus récente dans le passé, ou la prochaine si pas encore dépassée)
  const allDone=steps.every(function(s){return s.done;});
  let activeDl;
  if(allDone){
    // Production terminée → prochaine deadline future
    activeDl=deadlines.find(function(d){return d>=today;})||deadlines[deadlines.length-1];
  }else{
    // Production en cours → trouver la deadline que l'on devait respecter
    // = la première deadline >= date de début de production (ou la deadline la plus proche de la date de fin prévue)
    // Logique : si la fin prévue est après une deadline passée → on est en retard sur cette deadline
    // La deadline "en cours" = la première deadline qui n'est pas encore terminée par rapport au planning
    const startD=calState.startDate?new Date(calState.startDate+'T00:00:00'):null;
    if(startD){
      // La deadline active = la première deadline qui vient APRÈS le début de cette production
      activeDl=deadlines.find(function(d){return d>startD;});
      if(!activeDl)activeDl=deadlines[deadlines.length-1];
    }else{
      activeDl=deadlines.find(function(d){return d>=today;})||deadlines[deadlines.length-1];
    }
  }
  const nextDl=activeDl;
  // endDs remplacé par endReelDs et endTheoDs ci-dessous

  // Box écart — deux comparaisons :
  // 1. Fin réelle (restant) vs deadline contractuelle
  // 2. Fin théorique (tout) vs deadline contractuelle
  if(ecartBox){
    let html='<div style="display:flex;flex-direction:column;gap:6px;">';
    if(endDReel&&nextDl){
      const diffMs=nextDl.getTime()-endDReel.getTime();
      const diffDays=Math.round(diffMs/86400000);
      const dlStr=nextDl.toLocaleDateString('fr-FR',{day:'numeric',month:'long'});
      const endReelStr=endDReel.toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric'});
      if(diffDays>0){
        html+='<div><span style="font-size:13px;color:#1D9E75;font-weight:600;">✓ Fin prévue (restant) : '+endReelStr+' — '+diffDays+' j avant deadline du '+dlStr+'</span> <span style="font-size:12px;">😊</span></div>';
      }else if(diffDays<0){
        html+='<div><span style="font-size:13px;color:#E24B4A;font-weight:600;">⚠ Fin prévue (restant) : '+endReelStr+' — '+Math.abs(diffDays)+' j de retard sur deadline du '+dlStr+'</span> <span style="font-size:12px;">😟</span></div>';
      }else{
        html+='<div><span style="font-size:13px;color:#EF9F27;font-weight:600;">⚡ Fin prévue exactement le jour de la deadline ('+dlStr+')</span></div>';
      }
    }
    if(endDTheo&&nextDl){
      const diffMs2=nextDl.getTime()-endDTheo.getTime();
      const diffDays2=Math.round(diffMs2/86400000);
      const endTheoStr=endDTheo.toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric'});
      const col=diffDays2>=0?'#666':'#F0997B';
      html+='<div><span style="font-size:11px;color:'+col+';">Planning théorique complet : '+endTheoStr+(diffDays2<0?' ('+Math.abs(diffDays2)+' j après deadline)':' ('+diffDays2+' j avant deadline)')+'</span></div>';
    }
    html+='</div>';
    ecartBox.style.display=(endDReel||endDTheo)?'block':'none';
    if(endDReel||endDTheo)ecartBox.innerHTML=html;
  }

  // Carte des jours de fab
  const fabDays={};
  if(startD&&planning.length>0){
    planning.forEach(function(day,di){
      const d=dayDate(di);
      const ds=d.toISOString().slice(0,10);
      if(day.some(function(e){return !e.isHF&&e.stepId>0;}))fabDays[ds]=di+1;
    });
  }
  const hfDays={};
  Object.values(calState.horsForge||{}).forEach(function(h){if(h.date)hfDays[h.date]=h;});
  const endReelDs=endDReel?endDReel.toISOString().slice(0,10):'';
  const endTheoDs=endDTheo?endDTheo.toISOString().slice(0,10):'';

  // Construire les 12 mois
  const monthNames=['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
  annuel.innerHTML='';

  // Grille 3x4 ou colonne selon largeur
  const grid12=document.createElement('div');
  grid12.style.cssText='display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:10px;';
  annuel.appendChild(grid12);

  for(let m=0;m<12;m++){
    const monthBox=document.createElement('div');
    monthBox.style.cssText='background:#222;border:1px solid #333;border-radius:10px;padding:10px;';

    // Vérifier si ce mois contient une deadline
    const hasDeadline=deadlines.some(function(d){return d.getFullYear()===calViewYear&&d.getMonth()===m;});
    const hasEndReel=endDReel&&endDReel.getFullYear()===calViewYear&&endDReel.getMonth()===m;
    const hasEndTheoMonth=endDTheo&&endDTheo.getFullYear()===calViewYear&&endDTheo.getMonth()===m;
    if(hasDeadline)monthBox.style.borderColor='#6a2020';
    if(hasEndReel)monthBox.style.border='2px solid #1D9E75';
    else if(hasEndTheoMonth)monthBox.style.borderColor='#5a4000';

    const mTitle=document.createElement('div');
    mTitle.style.cssText='font-size:12px;font-weight:700;color:#aaa;margin-bottom:6px;text-align:center;';
    mTitle.textContent=monthNames[m];
    monthBox.appendChild(mTitle);

    const mGrid=document.createElement('div');
    mGrid.style.cssText='display:grid;grid-template-columns:repeat(7,1fr);gap:1px;';

    // En-têtes
    const dows2=['L','M','M','J','V','S','D'];
    dows2.forEach(function(dw){
      const h=document.createElement('div');
      h.style.cssText='font-size:9px;color:#555;text-align:center;padding:2px 0;font-weight:600;';
      h.textContent=dw;mGrid.appendChild(h);
    });

    const firstDay=new Date(calViewYear,m,1);
    let startDow=firstDay.getDay();if(startDow===0)startDow=7;
    const lastDay=new Date(calViewYear,m+1,0).getDate();

    // Vides avant
    for(let i=1;i<startDow;i++){
      const empty=document.createElement('div');mGrid.appendChild(empty);
    }

    for(let day2=1;day2<=lastDay;day2++){
      const d=new Date(calViewYear,m,day2);
      const ds=d.toISOString().slice(0,10);
      const dow=d.getDay();
      const isWE=dow===0||dow===6;
      const isTod=d.toDateString()===today.toDateString();
      const isFab=!!fabDays[ds];
      const isHF=!!hfDays[ds];
      const isDl=dlDates.has(ds);
      const isEnd=endReelDs===ds;
      const isEndTheo=endTheoDs===ds&&endTheoDs!==endReelDs;

      const cell=document.createElement('div');
      // Base style: neutral dark box
      let bg='transparent';let border='none';let opacity=isWE?'0.35':'1';
      if(isTod&&!isDl&&!isEnd){bg='#0d2a1e';border='2px solid #1D9E75';}
      else if(isFab&&!isDl&&!isEnd&&!isEndTheo){bg='#0a1a10';border='1px solid #1a3a20';}
      cell.style.cssText=`min-height:26px;border-radius:4px;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;padding:2px 1px;font-size:9px;cursor:default;background:${bg};border:${border};opacity:${opacity};position:relative;`;

      // Number
      const numEl=document.createElement('div');
      let numColor=isWE?'#444':'#777';
      if(isTod)numColor='#5DCAA5';
      else if(isFab)numColor='#5DCAA5';
      numEl.style.cssText='font-weight:'+(isTod||isDl||isEnd||isEndTheo?'700':'400')+';color:'+numColor+';line-height:1.3;font-size:9px;';
      numEl.textContent=day2;
      cell.appendChild(numEl);

      // Icon badges (stacked, max 3px height each)
      const iconsWrap=document.createElement('div');
      iconsWrap.style.cssText='display:flex;flex-direction:column;align-items:center;gap:1px;margin-top:1px;';

      if(isDl){
        // Red square flag
        const ic=document.createElement('div');
        ic.style.cssText='width:10px;height:5px;background:#E24B4A;border-radius:1px;display:flex;align-items:center;justify-content:center;';
        ic.innerHTML='<span style="font-size:7px;line-height:1;">🚩</span>';
        iconsWrap.appendChild(ic);
      }
      if(isEnd){
        // Green checkered flag
        const ic=document.createElement('div');
        ic.style.cssText='width:10px;height:5px;background:#1D9E75;border-radius:1px;display:flex;align-items:center;justify-content:center;';
        ic.innerHTML='<span style="font-size:7px;line-height:1;">✅</span>';
        iconsWrap.appendChild(ic);
      }
      if(isEndTheo&&!isEnd){
        const ic=document.createElement('div');
        ic.style.cssText='width:10px;height:5px;background:#EF9F27;border-radius:1px;display:flex;align-items:center;justify-content:center;';
        ic.innerHTML='<span style="font-size:7px;line-height:1;">🏁</span>';
        iconsWrap.appendChild(ic);
      }
      if(isTod){
        const ic=document.createElement('div');
        ic.style.cssText='width:8px;height:3px;border-radius:99px;background:#1D9E75;';
        iconsWrap.appendChild(ic);
      }
      if(isFab&&!isDl&&!isEnd&&!isEndTheo){
        const ic=document.createElement('div');
        ic.style.cssText='width:5px;height:5px;border-radius:50%;background:#1D9E75;opacity:0.85;';
        iconsWrap.appendChild(ic);
      }
      if(isHF&&!isDl){
        const ic=document.createElement('div');
        ic.style.cssText='width:8px;height:3px;border-radius:2px;background:#EF9F27;opacity:0.9;';
        iconsWrap.appendChild(ic);
      }
      if(iconsWrap.children.length>0)cell.appendChild(iconsWrap);

      // Tooltip
      let tip='';
      if(isDl)tip='🚩 Deadline contractuelle';
      if(isEnd)tip=(tip?'\n':'')+'✅ Fin prévue réelle (étapes restantes)';
      if(isEndTheo)tip=(tip?'\n':'')+'🏁 Fin théorique (planning total)';
      if(isFab)tip=(tip?'\n':'')+'Jour de fab. J'+fabDays[ds];
      if(isHF)tip=(tip?'\n':'')+'Hors prod: '+hfDays[ds].label;
      if(isTod)tip=(tip?'\n':'')+'Aujourd\'hui';
      if(tip)cell.title=tip;

      mGrid.appendChild(cell);
    }

    monthBox.appendChild(mGrid);
    grid12.appendChild(monthBox);
  }
}

