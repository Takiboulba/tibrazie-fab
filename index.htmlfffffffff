// ── Drag & drop sous-étapes ──
let subDragSrcId=null, subDragStepId=null;
function initSubDrag(stepId){
  const list=document.getElementById('sub-list-'+stepId);
  if(!list)return;
  const items=list.querySelectorAll('.sub-item');
  items.forEach(function(item){
    // Drag uniquement depuis la poignée
    const handle=item.querySelector('.sub-drag-handle');
    if(handle){
      handle.addEventListener('mousedown',function(){item.draggable=true;});
      item.addEventListener('dragend',function(){item.draggable=false;});
    }else{item.draggable=false;}

    item.addEventListener('dragstart',function(e){
      subDragSrcId=parseInt(item.dataset.subid);
      subDragStepId=parseInt(item.dataset.stepid);
      item.classList.add('sub-dragging');
      e.dataTransfer.effectAllowed='move';
      e.dataTransfer.setData('text/plain',subDragSrcId);
      e.stopPropagation(); // ne pas déclencher le drag de l'étape parente
    });
    item.addEventListener('dragend',function(){
      item.classList.remove('sub-dragging');
      list.querySelectorAll('.sub-item').forEach(function(i){i.classList.remove('sub-drag-over-top');i.classList.remove('sub-drag-over-bot');});
      subDragSrcId=null;subDragStepId=null;
    });
    item.addEventListener('dragover',function(e){
      e.preventDefault();e.stopPropagation();
      if(subDragSrcId===null||parseInt(item.dataset.subid)===subDragSrcId)return;
      list.querySelectorAll('.sub-item').forEach(function(i){i.classList.remove('sub-drag-over-top');i.classList.remove('sub-drag-over-bot');});
      const rect=item.getBoundingClientRect();
      if(e.clientY<rect.top+rect.height/2){item.classList.add('sub-drag-over-top');}
      else{item.classList.add('sub-drag-over-bot');}
    });
    item.addEventListener('dragleave',function(e){
      if(!item.contains(e.relatedTarget)){item.classList.remove('sub-drag-over-top');item.classList.remove('sub-drag-over-bot');}
    });
    item.addEventListener('drop',function(e){
      e.preventDefault();e.stopPropagation();
      item.classList.remove('sub-drag-over-top');item.classList.remove('sub-drag-over-bot');
      if(subDragSrcId===null||subDragStepId===null)return;
      const toId=parseInt(item.dataset.subid);
      if(toId===subDragSrcId)return;
      const step=steps.find(function(s){return s.id===subDragStepId;});
      if(!step)return;
      const fi=step.subs.findIndex(function(x){return x.id===subDragSrcId;});
      if(fi<0)return;
      const[moved]=step.subs.splice(fi,1);
      const rect=item.getBoundingClientRect();
      const after=e.clientY>=rect.top+rect.height/2;
      const newTi=step.subs.findIndex(function(x){return x.id===toId;});
      if(newTi<0)return;
      step.subs.splice(after?newTi+1:newTi,0,moved);
      save();renderSuivi();
    });
  });
}


