function renderPlanSummary(planning){
  const totalRef=steps.reduce((a,s)=>a+parseMins(s.ref),0);
  const doneCnt=steps.filter(s=>s.done).length;
  const totalRefMins2=steps.reduce((a,s)=>a+parseMins(s.ref),0);
  const doneRefMins2=steps.filter(s=>s.done).reduce((a,s)=>a+parseMins(s.ref),0);
  const pct=totalRefMins2>0?Math.round(doneRefMins2/totalRefMins2*100):Math.round(doneCnt/steps.length*100);
  let totalSpent=0;
  planning.forEach((day,di)=>{
    const ds=getCalDay(di);
    day.forEach(e=>{const sp=parseMins(ds.spent[e.stepId]);if(sp)totalSpent+=sp;});
  });
  Object.values(calState.customDays||{}).forEach(cd=>{
    (cd.entries||[]).forEach(e=>{const sp=parseMins(e.spent);if(sp)totalSpent+=sp;});
  });
  const endDate=dayDate(planning.length-1);
  document.getElementById('plan-summary').innerHTML=`
    <div class="psum-card"><div class="psum-l">Total fab.</div><div class="psum-v">${fmtMins(totalRef)}</div></div>
    <div class="psum-card"><div class="psum-l">Jours fab.</div><div class="psum-v">${planning.length}j</div></div>
    <div class="psum-card"><div class="psum-l">Avancement</div><div class="psum-v green">${pct}%</div></div>
    <div class="psum-card"><div class="psum-l">Temps passé</div><div class="psum-v">${totalSpent?fmtMins(totalSpent):'—'}</div></div>
    <div class="psum-card"><div class="psum-l">Fin prévue</div><div class="psum-v" style="font-size:11px">${calState.startDate?endDate.toLocaleDateString('fr-FR',{day:'numeric',month:'short'}):'—'}</div></div>`;
}

function renderPlanDays(planning){
  if(!planning)planning=buildPlanning();
  const wrap=document.getElementById('days-wrap');wrap.innerHTML='';
  let daysToShow=[];
  if(planView==='semaine'){
    const startD=getStartDate();
    const start=new Date(startD);
    start.setDate(start.getDate()+currentWeek*7);
