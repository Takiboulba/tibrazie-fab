function getCat(id){return cats.find(c=>c.id===id)||cats[0]||{name:'?',color:'#888',bg:'#222'};}
function calcStats(){
  const sd=steps.filter(s=>s.done).length,st=steps.length,sl=st-sd;
  const ssd=steps.reduce((a,s)=>a+s.subs.filter(x=>x.done).length,0);
  const sst=steps.reduce((a,s)=>a+s.subs.length,0),ssl=sst-ssd;
  const td=sd+ssd,tt=st+sst,pct=tt?Math.round(td/tt*100):0;
  return{sd,st,sl,ssd,sst,ssl,td,tt,pct};
}
function renderStats(){
  const c=calcStats();
  // Barre de progression basée sur les heures
  const totalRefMinsBar=steps.reduce(function(a,s){return a+parseMins(s.ref);},0);
  const doneRefMinsBar=steps.filter(function(s){return s.done;}).reduce(function(a,s){return a+parseMins(s.ref);},0);
  const pctBar=totalRefMinsBar>0?Math.round(doneRefMinsBar/totalRefMinsBar*100):c.pct;
  document.getElementById('pbar').style.width=pctBar+'%';
  const g=document.getElementById('stat-grid');g.innerHTML='';
  statOrder.forEach(id=>{
    const def=STAT_DEFS.find(x=>x.id===id);
    let v,sub='';
