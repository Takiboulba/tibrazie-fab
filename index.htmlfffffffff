const DAY_MINS=480;
function buildPlanning(){
  // Toujours toutes les étapes pour l'affichage du planning
  const days=[];let cur=[],curM=0;
  steps.forEach(function(s){
    let rem=parseMins(s.ref),first=true;
    while(rem>0){
      if(curM>=DAY_MINS){days.push(cur);cur=[];curM=0;}
      const use=Math.min(rem,DAY_MINS-curM);
      cur.push({stepId:s.id,name:s.name,ref:s.ref,refMins:parseMins(s.ref),allocMins:use,partial:!first||use<parseMins(s.ref),custom:false});
      curM+=use;rem-=use;first=false;
      if(curM>=DAY_MINS){days.push(cur);cur=[];curM=0;}
    }
  });
  if(cur.length)days.push(cur);
  // Ajouter des jours vides pour les hors-forge partiels (temps perdu)
  const extra=extraDaysFromHF?extraDaysFromHF():0;
  for(let i=0;i<extra;i++) days.push([{stepId:-1,name:'Hors production',ref:'',refMins:0,allocMins:0,partial:false,custom:true,isHF:true}]);
  return days;
}

// Fin prévue réelle = aujourd'hui + jours de fab restants (en minutes restantes)
// Calcul direct depuis les minutes des étapes non cochées → pas besoin de buildPlanning
function getFinalDatePrevue(){
  if(!calState.startDate)return null;
  // Calculer les minutes restantes (étapes non cochées uniquement)
  const minsRestants=steps.filter(function(s){return !s.done;})
    .reduce(function(a,s){return a+parseMins(s.ref);},0);
  if(minsRestants<=0)return new Date(); // tout terminé = aujourd'hui
  // Convertir en jours de 8H ouvrés restants
  const joursRestants=Math.ceil(minsRestants/DAY_MINS);
  const today=new Date();today.setHours(0,0,0,0);
  return addOuvres(today, joursRestants);
}

// Fin prévue THÉORIQUE = date début + total jours de fab (planning complet)
function getFinalDateTheorique(){
  if(!calState.startDate)return null;
  const planning=buildPlanning();
  if(planning.length===0)return null;
  return dayDate(planning.length-1);
}

// Ajouter N jours ouvrés à partir d'une date (skip week-end et hors-forge)
function addOuvres(from, n){
  let d=new Date(from);let added=0;
  while(added<n){
    d.setDate(d.getDate()+1);
    const dow=d.getDay();
    const ds=d.toISOString().slice(0,10);
    const hfDay=Object.values(calState.horsForge||{}).filter(function(h){return h.date===ds;});
    const isFullHF=hfDay.some(function(h){return h.duration==='journée'||h.mins>=DAY_MINS;});
    if(dow!==0&&dow!==6&&!isFullHF) added++;
  }
  return d;
}

function getStartDate(){return calState.startDate?new Date(calState.startDate+'T00:00:00'):new Date();}
// dayDate : convertit un index de jour de fabrication en date réelle
// en sautant les week-ends et les jours marqués "hors production"
function dayDate(di){
  const start=getStartDate();
  let d=new Date(start);
  let workDays=0;
  while(workDays<di){
    d.setDate(d.getDate()+1);
    const dow=d.getDay();
    if(dow===0||dow===6)continue; // skip week-end
    const dateStr=d.toISOString().slice(0,10);
    if((calState.horsForge||{})[dateStr])continue; // skip hors-forge
    workDays++;
  }
  // Avancer encore si le premier jour tombe week-end ou hors-forge
  while(true){
    const dow=d.getDay();
    const dateStr=d.toISOString().slice(0,10);
    if((dow===0||dow===6)||(calState.horsForge||{})[dateStr]){d.setDate(d.getDate()+1);continue;}
    break;
  }
  return d;
}
// Nombre de jours ouvrés entre deux dates (hors week-end et hors-forge complets)
function ouvrés(from,to){
  let count=0;let d=new Date(from);d.setHours(0,0,0,0);
  const toD=new Date(to);toD.setHours(0,0,0,0);
  while(d<=toD){
    const dow=d.getDay();
    const ds=d.toISOString().slice(0,10);
    // Chercher un hors-forge complet sur cette date (par h.date)
    const hfEntries2=Object.values(calState.horsForge||{}).filter(h=>h.date===ds);
    const isFullHF=hfEntries2.some(h=>h.duration==='journée'||h.mins>=DAY_MINS);
    if(dow!==0&&dow!==6&&!isFullHF)count++;
    d.setDate(d.getDate()+1);
  }
  return count;
}
// Calcule combien de jours de fab supplémentaires les hors-forge partiels ajoutent
function extraDaysFromHF(){
  const hf=calState.horsForge||{};
  let extraMins=0;
  Object.values(hf).forEach(h=>{
    // Journée partielle : on perd ces minutes de production
    if(h.duration!=='journée'&&h.mins<DAY_MINS)extraMins+=h.mins;
  });
  return Math.ceil(extraMins/DAY_MINS);
}
function fmtDateShort(d){return d.toLocaleDateString('fr-FR',{weekday:'short',day:'numeric',month:'short'});}
function isToday(d){return d.toDateString()===new Date().toDateString();}
function isPast(d){const t=new Date();t.setHours(0,0,0,0);return d<t;}
function getCalDay(di){if(!calState.days[di])calState.days[di]={done:{},spent:{},notes:''};return calState.days[di];}

// Liaison Planning → Suivi : cocher dans planning coche dans steps
function togglePlanStep(stepId){
  const s=steps.find(x=>x.id===stepId);
  if(s){
    s.done=!s.done;
    if(s.done){s.doneDate=new Date().toISOString().slice(0,10);}
