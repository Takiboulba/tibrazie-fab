// TEMPS — parseMins corrigé (9H45 = 9h + 45min)
// ════════════════════════════════════════════════
function parseMins(s){
  if(!s||!s.trim())return 0;
  s=s.trim().toUpperCase().replace(',','.');
  const hm=s.match(/^(\d+(?:\.\d+)?)H(\d+)?$/);
  if(hm)return Math.round(parseFloat(hm[1])*60+(hm[2]?parseFloat(hm[2]):0));
  const h=s.match(/(\d+(?:\.\d+)?)H/);
  const m=s.match(/(\d+(?:\.\d+)?)M(?:IN)?(?!\w)/);
  let t=0;
  if(h){
    t+=parseFloat(h[1])*60;
    // Chiffres directement après H sans M → minutes
    const afterH=s.slice(h.index+h[0].length).trim();
    if(!m&&afterH){const n=afterH.match(/^(\d+)/);if(n)t+=parseFloat(n[1]);}
  }
  if(m)t+=parseFloat(m[1]);
  if(!h&&!m){const n=parseFloat(s);if(!isNaN(n))t=n;}
  return Math.round(t);
}
function fmtMins(m){
  if(!m||m<=0)return'—';
  const h=Math.floor(m/60),mn=m%60;
  return h>0?(mn>0?h+'H'+String(mn).padStart(2,'0'):h+'H'):mn+'min';
}
function fmtDiff(spent,ref){
  if(!spent||!ref)return null;
  const d=spent-ref;
  return{txt:(d>=0?'+':'-')+fmtMins(Math.abs(d)),pos:d>0,neg:d<0};
}

