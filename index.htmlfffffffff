function archiveProduction(){
  const done=steps.filter(s=>s.done).length;
  const total=steps.length;
  if(done===0){alert('Aucune étape terminée à archiver.');return;}

  // pct basé sur les heures (pas le nombre d'étapes)
  const totalRefMinsForPct=steps.reduce((a,s)=>a+parseMins(s.ref),0);
  const doneRefMinsForPct=steps.filter(s=>s.done).reduce((a,s)=>a+parseMins(s.ref),0);
  const pct=totalRefMinsForPct>0?Math.round(doneRefMinsForPct/totalRefMinsForPct*100):Math.round(done/total*100);
  const msg=pct<100?
    `Archiver la production en cours (${pct}% terminée) ?\nVous pourrez continuer à travailler dessus, l'archive est une photo à cet instant.`:
    `Production terminée à 100% ! Archiver ?`;
  if(!confirm(msg))return;

  const planning=buildPlanning();
  // Calcul temps total passé sur étapes
  let totalRefMins=0,totalSpentMins=0;
  steps.forEach(s=>{
    totalRefMins+=parseMins(s.ref);
    if(s.spent)totalSpentMins+=parseMins(s.spent);
  });
  // Temps hors-forge
  const hf=calState.horsForge||{};
  const hfEntries=Object.entries(hf).map(([date,h])=>({date,label:h.label,duration:h.duration,mins:h.mins}));
  const totalHfMins=hfEntries.reduce((a,h)=>a+h.mins,0);
  // Étapes avec temps
  const stepDetails=steps.map(s=>({
    id:s.id,name:s.name,ref:s.ref,spent:s.spent,done:s.done,
    refMins:parseMins(s.ref),spentMins:parseMins(s.spent),cat:s.cat
  }));
  // Journées custom (bureau, etc)
  const customEntries=[];
  Object.values(calState.customDays||{}).forEach(cd=>{
    (cd.entries||[]).forEach(e=>{customEntries.push({name:e.name,spent:e.spent,mins:parseMins(e.spent),dayTitle:cd.title});});
  });
  const totalCustomMins=customEntries.reduce((a,e)=>a+e.mins,0);

  // Snapshot stock pour le rapport
  const st=getStock();
  const stockSnapshot={
    serieSize:st.serieSize,
    seriesAvance:st.seriesAvance,
    urgents:[],
    warnings:[],
    ok:[]
  };
  [...st.pieces,...st.accessoires,...(st.consommables||[])].forEach(function(row){
    const status=getStockStatus(row,st.serieSize,st.seriesAvance);
    const entry={nom:row.nom,qteParPoele:row.qteParPoele,stock:row.stock,qteSerie:row.qteParPoele*st.serieSize,status};
    if(status==='danger')stockSnapshot.urgents.push(entry);
    else if(status==='warn')stockSnapshot.warnings.push(entry);
    else stockSnapshot.ok.push(entry);
  });

  // Calendrier par date réelle de cochage
  const realDayCalendar=(function(){
    // Regrouper les étapes par leur date réelle de cochage
    const byDate={};
    steps.forEach(function(s){
      const dateKey=s.doneDate||(s.done?new Date().toISOString().slice(0,10):null);
      if(!dateKey)return;
      if(!byDate[dateKey])byDate[dateKey]={steps:[],hf:[],spentMins:0,refMins:0};
      byDate[dateKey].steps.push({
        id:s.id,name:s.name,ref:s.ref,refMins:parseMins(s.ref),
        spentMins:parseMins(s.spent),done:s.done,cat:s.cat
      });
      byDate[dateKey].refMins+=parseMins(s.ref);
      byDate[dateKey].spentMins+=parseMins(s.spent||s.ref);
    });
    // Ajouter les temps hors production
    Object.values(calState.horsForge||{}).forEach(function(h){
      if(!h.date)return;
      if(!byDate[h.date])byDate[h.date]={steps:[],hf:[],spentMins:0,refMins:0};
      byDate[h.date].hf.push({label:h.label,duration:h.duration,mins:h.mins});
    });
    // Convertir en tableau trié
    return Object.entries(byDate)
      .sort(function(a,b){return a[0].localeCompare(b[0]);})
      .map(function([date,data]){return{date,steps:data.steps,hf:data.hf,refMins:data.refMins,spentMins:data.spentMins};});
  })();

  // Snapshot du tableau post-fab (temps bureau) — ÉDITABLE après archivage
  const pfSnap=JSON.parse(JSON.stringify(getPostFab()));

  const archive={
    id:'prod_'+Date.now(),
    title:'Production '+(new Date().toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric'})),
    archivedAt:new Date().toISOString(),
    startDate:calState.startDate||'',
    pct,done,total,
    totalRefMins,totalSpentMins,totalHfMins,totalCustomMins,
    totalDays:planning.length,
    stepDetails,hfEntries,customEntries,
    cats:JSON.parse(JSON.stringify(cats)),
    stockSnapshot,
    postFabSnapshot:pfSnap,
    realDayCalendar,
    // Calendrier journalier de production
    dailyCalendar:(function(){
      if(!calState.startDate)return[];
      const calendar=[];
      planning.forEach(function(day,di){
        const d=dayDate(di);
        const ds=getCalDay(di);
        const dateStr=d.toISOString().slice(0,10);
        const entries=day.filter(function(e){return e.stepId>0&&!e.isHF;});
        if(entries.length===0)return;
        let dayTotalMins=0;
        const dayEntries=entries.map(function(e){
          const spentMins=parseMins(ds.spent[e.stepId]||'')||0;
          dayTotalMins+=spentMins||e.allocMins;
          return{stepId:e.stepId,name:e.name,ref:e.ref,refMins:e.allocMins,spentMins,partial:e.partial};
        });
        calendar.push({dayNum:di+1,date:dateStr,notes:ds.notes||'',entries:dayEntries,totalMins:dayTotalMins});
      });
      return calendar;
    })()
  };

  if(!calState.archives)calState.archives=[];
  calState.archives.unshift(archive);
  if(calState.archives.length>20)calState.archives.length=20; // max 20 archives
  save();
  renderRapports();
  alert('✅ Production archivée ! Consultez l\'onglet Rapports.');
}

function clearArchives(){
  if(!calState.archives||calState.archives.length===0){alert('Aucune archive.');return;}
  if(!confirm('Supprimer toutes les archives ?'))return;
  calState.archives=[];save();renderRapports();
}
function delArchive(id){
  if(!confirm('Supprimer ce rapport ?'))return;
  calState.archives=(calState.archives||[]).filter(a=>a.id!==id);
  save();renderRapports();
}

function renderRapports(){
  const list=document.getElementById('rapports-list');
  const archives=calState.archives||[];
  if(archives.length===0){
    list.innerHTML='<div style="text-align:center;color:#555;padding:40px;font-size:13px;">Aucun rapport archivé.\nArchivez une production pour voir les rapports ici.</div>';
    return;
  }
  list.innerHTML=archives.map((a)=>buildRapportHTML(a)).join('');
  // Remettre le filtre de recherche si actif
  const q=document.getElementById('rapport-search');
  if(q&&q.value.trim())filterRapportSearch();
}

function filterRapportSearch(){
  const q=(document.getElementById('rapport-search').value||'').trim().toLowerCase();
  const archives=calState.archives||[];
  const resultsBox=document.getElementById('rapport-search-results');
  if(!q){
    resultsBox.style.display='none';
    resultsBox.innerHTML='';
    // Réafficher tous les rapports normalement
    document.getElementById('rapports-list').innerHTML=archives.map(a=>buildRapportHTML(a)).join('');
    return;
  }
  // Chercher dans tous les rapports les étapes correspondantes
  let found=[];
  archives.forEach(a=>{
    const matches=(a.stepDetails||[]).filter(s=>s.name.toLowerCase().includes(q));
    if(matches.length>0)found.push({archive:a,matches});
  });
  if(found.length===0){
    resultsBox.style.display='block';
    resultsBox.innerHTML=`<div style="color:#555;font-size:12px;padding:8px 0;">Aucune étape « ${q} » dans vos rapports.</div>`;
    document.getElementById('rapports-list').innerHTML=archives.map(a=>buildRapportHTML(a)).join('');
    return;
  }
  // Afficher un résumé des résultats et ouvrir automatiquement les rapports correspondants
  resultsBox.style.display='block';
  resultsBox.innerHTML=`<div style="font-size:11px;color:#1D9E75;margin-bottom:6px;">✓ ${found.reduce((n,f)=>n+f.matches.length,0)} étape(s) trouvée(s) dans ${found.length} rapport(s)</div>
  ${found.map(f=>`<div style="font-size:11px;color:#888;padding:2px 0;">
    <span style="color:#e0e0e0;font-weight:600;">${f.archive.title}</span> — 
    ${f.matches.map(m=>`<span style="color:#5DCAA5;cursor:pointer;" onclick="document.getElementById('rcard-${f.archive.id}').classList.add('open');document.getElementById('rcard-${f.archive.id}').scrollIntoView({behavior:'smooth',block:'start'});">${m.name}</span>`).join(', ')}
  </div>`).join('')}`;
  // Mettre à jour la liste en surlignant les étapes
  document.getElementById('rapports-list').innerHTML=archives.map(a=>{
    const matchArchive=found.find(f=>f.archive.id===a.id);
    return buildRapportHTML(a, matchArchive?q:'', !!matchArchive);
  }).join('');
}

function buildRapportHTML(a, highlightTerm, autoOpen){
  const arcDate=new Date(a.archivedAt).toLocaleDateString('fr-FR',{day:'numeric',month:'short',year:'numeric'});
  // Calcul total postFab depuis le snapshot (mis à jour si édité)
  const pfSnap=a.postFabSnapshot||{title:'Temps bureau',cats:[],items:[]};
  let pfTotRef=0,pfTotSpent=0;
  (pfSnap.items||[]).forEach(item=>{
    pfTotRef+=parseMins(item.ref);pfTotSpent+=parseMins(item.spent);
    (item.subs||[]).forEach(s=>{pfTotRef+=parseMins(s.ref);pfTotSpent+=parseMins(s.spent);});
  });

  const diff=a.totalSpentMins-a.totalRefMins;
  const diffColor=diff>0?'#F0997B':diff<0?'#5DCAA5':'#888';
  const diffTxt=diff===0?'—':(diff>0?'+':'')+fmtMins(Math.abs(diff));

  // Graphique circulaire SVG
  const pieSVG=buildPieSVG(a);

  // Tableau étapes par catégorie
  const catsTable=buildCatsTable(a, highlightTerm);

  // HF summary
  const hfByLabel={};
  (a.hfEntries||[]).forEach(h=>{hfByLabel[h.label]=(hfByLabel[h.label]||0)+h.mins;});
  const customByName={};
  (a.customEntries||[]).forEach(e=>{customByName[e.name]=(customByName[e.name]||0)+e.mins;});

  // Preview (toujours visible)
  const preview=`
    <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:flex-start;padding:12px 13px;">
      <div style="flex:0 0 auto;">${pieSVG}</div>
      <div style="flex:1;min-width:150px;">
        <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:8px;">
          <div class="rstat"><div class="rstat-l">Avancement</div><div class="rstat-v" style="color:${a.pct===100?'#1D9E75':'#EF9F27'}">${a.pct}%</div></div>
          <div class="rstat"><div class="rstat-l">Étapes</div><div class="rstat-v">${a.done}/${a.total}</div></div>
          <div class="rstat"><div class="rstat-l">Réf.</div><div class="rstat-v">${fmtMins(a.totalRefMins)}</div></div>
          <div class="rstat"><div class="rstat-l">Réel fab.</div><div class="rstat-v ${diff>0?'red':diff<0?'green':''}">${a.totalSpentMins?fmtMins(a.totalSpentMins):'—'}</div></div>
          <div class="rstat"><div class="rstat-l">Écart</div><div class="rstat-v" style="color:${diffColor}">${diffTxt}</div></div>
          ${a.totalHfMins?`<div class="rstat"><div class="rstat-l">Hors prod.</div><div class="rstat-v orange">${fmtMins(a.totalHfMins)}</div></div>`:''}
          ${pfTotSpent?`<div class="rstat" style="background:#1a0a2a;border-color:#5a3a8a;"><div class="rstat-l" style="color:#c090f0;">${pfSnap.title||'Post-fab'}</div><div class="rstat-v" style="color:#c090f0;">${fmtMins(pfTotSpent)}</div></div>`:''}
          ${a.totalCustomMins?`<div class="rstat"><div class="rstat-l">Bureau/autre</div><div class="rstat-v">${fmtMins(a.totalCustomMins)}</div></div>`:''}
        </div>
      </div>
    </div>`;

  // Section post-fab éditable dans le rapport
  const postFabSection=buildRapportPostFabHTML(a);

  // Stock snapshot
  const snap=a.stockSnapshot;
  let stockSection='';
  if(snap){
    const hasIssues=(snap.urgents&&snap.urgents.length>0)||(snap.warnings&&snap.warnings.length>0);
    const urgentRows=(snap.urgents||[]).map(function(r){
      return`<div style="display:flex;align-items:center;gap:8px;padding:4px 0;border-bottom:1px solid #2a1a1a;">
        <span style="font-size:12px;">🚨</span>
        <span style="color:#F0997B;font-weight:600;flex:1;font-size:12px;">${r.nom}</span>
        <span style="font-size:11px;color:#888;">Stock : <b style="color:#e8e8e8;">${r.stock}</b> | Série : <b style="color:#e8e8e8;">${r.qteSerie}</b></span>
      </div>`;
    }).join('');
    const warnRows=(snap.warnings||[]).map(function(r){
      return`<div style="display:flex;align-items:center;gap:8px;padding:4px 0;border-bottom:1px solid #1a1a0a;">
        <span style="font-size:12px;">⚠️</span>
        <span style="color:#EF9F27;font-weight:600;flex:1;font-size:12px;">${r.nom}</span>
        <span style="font-size:11px;color:#888;">Stock : <b style="color:#e8e8e8;">${r.stock}</b> | Série : <b style="color:#e8e8e8;">${r.qteSerie}</b></span>
      </div>`;
    }).join('');
    stockSection=`<div style="background:${hasIssues?'#1a0d0d':'#0d1a10'};border:1px solid ${hasIssues?'#4a1a1a':'#1a3a1a'};border-radius:10px;padding:10px 12px;margin-bottom:10px;">
      <div style="font-size:12px;font-weight:700;color:${hasIssues?'#F0997B':'#5DCAA5'};margin-bottom:6px;">
        📦 État du stock au moment de l'archivage — série de ${snap.serieSize} poêles · marge ${snap.seriesAvance} série(s)
      </div>
      ${hasIssues?urgentRows+warnRows:`<div style="color:#5DCAA5;font-size:12px;">✓ Toutes les pièces étaient en stock suffisant</div>`}
      ${(snap.urgents&&snap.urgents.length>0)?`<div style="font-size:10px;color:#666;margin-top:6px;">⚠ ${snap.urgents.length} pièce(s) en rupture — à commander avant la prochaine série</div>`:''}
    </div>`;
  }

  // Calendrier par dates réelles de cochage
  const realCalHtml=(function(){
    const calendar=a.realDayCalendar||[];
    if(calendar.length===0){
      // Fallback: ancien format
      const old=a.dailyCalendar||[];
      if(old.length===0)return'';
      const rows2=old.map(function(day){
        const d=new Date(day.date+'T00:00:00');
        const dateLabel=d.toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
        const totalH=fmtMins(day.totalMins);
        const stepRows=day.entries.map(function(e){
          const spentLabel=e.spentMins?'<span style="color:#85B7EB;font-size:10px;"> · réel : '+fmtMins(e.spentMins)+'</span>':'';
          return`<div style="display:flex;align-items:center;gap:6px;padding:3px 0;border-bottom:1px solid #252525;font-size:11px;">
            <span style="color:#888;flex:1;">${e.name}</span>
            <span style="color:#5DCAA5;white-space:nowrap;">${fmtMins(e.refMins)}</span>${spentLabel}
          </div>`;
        }).join('');
        return`<div style="background:#1e1e1e;border:1px solid #2a2a2a;border-radius:10px;padding:10px 12px;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
            <div style="font-size:12px;font-weight:700;color:#e8e8e8;">Jour ${day.dayNum} — <span style="color:#5DCAA5;">${dateLabel}</span></div>
            <div style="font-size:11px;font-weight:600;color:#EF9F27;">Total : ${totalH}</div>
          </div>
          ${stepRows}
          ${day.notes?`<div style="font-size:10px;color:#666;padding-top:4px;font-style:italic;">📝 ${day.notes}</div>`:''}
        </div>`;
      }).join('');
      return`<div style="margin:0 0 12px;"><div style="font-size:13px;font-weight:700;color:#888;margin-bottom:8px;letter-spacing:.3px;">📆 Calendrier de production (planning théorique)</div><div style="display:flex;flex-direction:column;gap:8px;">${rows2}</div></div>`;
    }
    const catsRef=a.cats||DEFAULT_CATS;
    const rows=calendar.map(function(day){
      const d=new Date(day.date+'T00:00:00');
      const dateLabel=d.toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
      const weekday=d.toLocaleDateString('fr-FR',{weekday:'long'});
      const stepRows=day.steps.length>0?day.steps.map(function(s){
        const cat=catsRef.find(function(c){return c.id===s.cat;})||{color:'#888'};
        const spentLabel=s.spentMins?'<span style="color:#85B7EB;font-size:10px;white-space:nowrap;"> · réel : '+fmtMins(s.spentMins)+'</span>':'';
        return`<div style="display:flex;align-items:center;gap:7px;padding:4px 0;border-bottom:1px solid #252525;font-size:11px;">
          <span style="width:7px;height:7px;border-radius:50%;background:${cat.color};flex-shrink:0;"></span>
          <span style="color:#e0e0e0;flex:1;">${s.name}</span>
          <span style="color:#5DCAA5;white-space:nowrap;">${fmtMins(s.refMins)}</span>${spentLabel}
          <span style="font-size:10px;margin-left:4px;">${s.done?'✅':'⬜'}</span>
        </div>`;
      }).join(''):'';
      const hfRows=day.hf&&day.hf.length>0?day.hf.map(function(h){
        return`<div style="display:flex;align-items:center;gap:7px;padding:4px 0;border-bottom:1px solid #252525;font-size:11px;background:#2a1800;border-radius:4px;padding:4px 7px;margin-top:3px;">
          <span style="color:#EF9F27;">⏸</span>
          <span style="color:#EF9F27;flex:1;">${h.label}</span>
          <span style="color:#EF9F27;font-size:10px;">${h.duration==='journée'?'Journée complète':fmtMins(h.mins)}</span>
        </div>`;
      }).join(''):'';
      const totalRefLabel=day.refMins?'<span style="color:#5DCAA5;font-size:11px;">⏱ Réf: '+fmtMins(day.refMins)+'</span>':'';
      const totalSpentLabel=day.spentMins?'<span style="color:#85B7EB;font-size:11px;"> · Réel: '+fmtMins(day.spentMins)+'</span>':'';
      return`<div style="background:#1e1e1e;border:1px solid #2a2a2a;border-radius:10px;padding:10px 12px;">
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:4px;margin-bottom:7px;">
          <div>
            <div style="font-size:13px;font-weight:700;color:#e8e8e8;">${dateLabel.charAt(0).toUpperCase()+dateLabel.slice(1)}</div>
            ${(day.steps.length>0||day.hf.length>0)?`<div style="font-size:11px;color:#666;margin-top:1px;">${day.steps.length} étape${day.steps.length>1?'s':''} cochée${day.steps.length>1?'s':''}${day.hf.length>0?' · '+day.hf.length+' hors prod.':''}</div>`:''}
          </div>
          <div>${totalRefLabel}${totalSpentLabel}</div>
        </div>
        ${stepRows}${hfRows}
      </div>`;
    }).join('');
    return`<div style="margin:0 0 12px;">
      <div style="font-size:13px;font-weight:700;color:#5DCAA5;margin-bottom:8px;letter-spacing:.3px;">📅 Calendrier réel de production — date par date</div>
      <div style="font-size:11px;color:#555;margin-bottom:8px;">Étapes cochées par date réelle, avec temps hors production</div>
      <div style="display:flex;flex-direction:column;gap:8px;">${rows}</div>
    </div>`;
  })();

  // Détail (déplié)
  const detail=`
    <div class="rapport-body">
      ${stockSection}
      ${realCalHtml}
      ${catsTable}
      ${Object.keys(hfByLabel).length?`<div class="hf-summary" style="margin:0 0 10px;">
        <div class="hf-summary-title">⏸ Temps hors production (total par catégorie)</div>
        ${Object.entries(hfByLabel).map(([label,mins])=>`<div class="hf-row"><span class="hf-row-name">${label}</span><span class="hf-row-time">${fmtMins(mins)}</span></div>`).join('')}
      </div>`:''}
      ${Object.keys(customByName).length?`<div class="hf-summary" style="margin:0 0 10px;">
        <div class="hf-summary-title">🗂 Temps bureau / autres activités (ancien)</div>
        ${Object.entries(customByName).map(([name,mins])=>`<div class="hf-row"><span style="color:#c090f0">${name}</span><span class="hf-row-time">${fmtMins(mins)}</span></div>`).join('')}
      </div>`:''}
      <div id="postfab-rapport-${a.id}">${postFabSection}</div>
      <div style="margin-top:8px;display:flex;justify-content:flex-end;gap:6px;">
        <button class="btn btn-b" style="height:28px;font-size:11px;" onclick="downloadRapport('${a.id}');event.stopPropagation();">⬇ Télécharger HTML</button>
      </div>
    </div>`;

  return`<div class="rapport-card${autoOpen?' open':''}" id="rcard-${a.id}">
    <div class="rapport-hdr" onclick="toggleRapport('${a.id}')">
      <div style="flex:1;min-width:0;">
        <div class="rapport-title" id="rtitle-${a.id}">${a.title}</div>
        <div class="rapport-date">Archivé le ${arcDate} • ${a.startDate?'Début : '+new Date(a.startDate+'T00:00:00').toLocaleDateString('fr-FR',{day:'numeric',month:'short'}):''}  • ${a.totalDays}j de fab.</div>
      </div>
      <div style="display:flex;gap:5px;align-items:center;flex-shrink:0;">
        <button class="btn" style="height:26px;font-size:11px;" onclick="renameRapport('${a.id}');event.stopPropagation();">✏</button>
        <button class="btn btn-r" style="height:26px;font-size:11px;" onclick="delArchive('${a.id}');event.stopPropagation();" title="Supprimer ce rapport">🗑</button>
        <span class="day-chev">▼</span>
      </div>
    </div>
    ${preview}
    ${detail}
  </div>`;
}

// ── Post-fab dans le rapport (éditable en direct) ──
function buildRapportPostFabHTML(a){
  const pf=a.postFabSnapshot||{title:'Temps bureau / post-fabrication',cats:[],items:[]};
  const title=pf.title||'Temps bureau / post-fabrication';
  let totRef=0,totSpent=0;
  (pf.items||[]).forEach(item=>{
    totRef+=parseMins(item.ref);totSpent+=parseMins(item.spent);
    (item.subs||[]).forEach(s=>{totRef+=parseMins(s.ref);totSpent+=parseMins(s.spent);});
  });

  // Lignes d'items groupées par catégorie
  let rows='';
  const cats2=pf.cats&&pf.cats.length>0?pf.cats:DEFAULT_POSTFAB_CATS;
  cats2.forEach(cat=>{
    const items=(pf.items||[]).filter(i=>i.cat===cat.id);
    if(items.length===0)return;
    rows+=`<div style="margin-bottom:4px;">
      <div style="display:flex;align-items:center;gap:5px;padding:4px 0 2px;">
        <div style="width:7px;height:7px;border-radius:50%;background:${cat.color};flex-shrink:0;"></div>
        <span style="font-size:10px;font-weight:700;color:${cat.color};">${cat.name}</span>
      </div>`;
    items.forEach(item=>{
      rows+=`<div style="display:flex;align-items:center;gap:6px;padding:4px 7px;background:#1c1228;border:1px solid #2a1a3a;border-radius:7px;margin-bottom:3px;flex-wrap:wrap;" id="rpf-item-${a.id}-${item.id}">
        <span style="flex:1;font-size:12px;color:#d0c0e0;min-width:80px;">${item.name}</span>
        ${item.ref?`<span style="font-size:10px;color:#7a60a0;">Réf: ${item.ref}</span>`:''}
        <span style="font-size:10px;color:#888;">Passé:</span>
        <input type="text" value="${item.spent||''}" placeholder="0H" style="width:65px;height:24px;font-size:11px;padding:0 6px;border:1px solid #4a3a6a;border-radius:6px;background:#2a1a3a;color:#c090f0;text-align:center;"
          onchange="saveRapportPostFabSpent('${a.id}',${item.id},null,this.value)"
          onblur="saveRapportPostFabSpent('${a.id}',${item.id},null,this.value)">
      </div>`;
      // Sous-items
      (item.subs||[]).forEach(sub=>{
        rows+=`<div style="display:flex;align-items:center;gap:5px;padding:3px 7px 3px 20px;flex-wrap:wrap;">
          <span style="flex:1;font-size:11px;color:#a090c0;">↳ ${sub.text}</span>
          ${sub.ref?`<span style="font-size:9px;color:#5a4a7a;">Réf: ${sub.ref}</span>`:''}
          <span style="font-size:9px;color:#666;">Passé:</span>
          <input type="text" value="${sub.spent||''}" placeholder="0H" style="width:60px;height:22px;font-size:11px;padding:0 5px;border:1px solid #3a2a5a;border-radius:5px;background:#1c1228;color:#c090f0;text-align:center;"
            onchange="saveRapportPostFabSpent('${a.id}',${item.id},${sub.id},this.value)"
            onblur="saveRapportPostFabSpent('${a.id}',${item.id},${sub.id},this.value)">
        </div>`;
      });
    });
    rows+=`</div>`;
  });
  // Items sans catégorie connue
  const unknownItems=(pf.items||[]).filter(i=>!cats2.find(c=>c.id===i.cat));
  if(unknownItems.length>0){
    rows+=`<div style="margin-bottom:4px;"><div style="font-size:10px;color:#666;padding:4px 0 2px;">Autres</div>`;
    unknownItems.forEach(item=>{
      rows+=`<div style="display:flex;align-items:center;gap:6px;padding:4px 7px;background:#1c1228;border:1px solid #2a1a3a;border-radius:7px;margin-bottom:3px;flex-wrap:wrap;">
        <span style="flex:1;font-size:12px;color:#d0c0e0;">${item.name}</span>
        <input type="text" value="${item.spent||''}" placeholder="0H" style="width:65px;height:24px;font-size:11px;padding:0 6px;border:1px solid #4a3a6a;border-radius:6px;background:#2a1a3a;color:#c090f0;text-align:center;"
          onchange="saveRapportPostFabSpent('${a.id}',${item.id},null,this.value)"
          onblur="saveRapportPostFabSpent('${a.id}',${item.id},null,this.value)">
      </div>`;
    });
    rows+=`</div>`;
  }

  // Bouton ajouter une tâche
  const addBtn=`<div style="display:flex;gap:5px;margin-top:6px;flex-wrap:wrap;">
    <input type="text" id="rpf-new-name-${a.id}" placeholder="Nouvelle tâche post-fab..." style="flex:2;height:27px;font-size:11px;padding:0 8px;border:1px solid #4a3a6a;border-radius:6px;background:#1c1228;color:#e8e8e8;" onkeydown="if(event.key==='Enter')addRapportPostFabItem('${a.id}')">
    <input type="text" id="rpf-new-time-${a.id}" placeholder="Réf." style="width:60px;height:27px;font-size:11px;padding:0 6px;border:1px solid #4a3a6a;border-radius:6px;background:#1c1228;color:#e8e8e8;">
    <button class="btn btn-p" style="height:27px;font-size:11px;padding:0 10px;" onclick="addRapportPostFabItem('${a.id}')">+ Ajouter</button>
  </div>`;

  return`<div style="background:#1a1025;border:1px solid #5a3a8a;border-radius:10px;padding:10px 12px;margin-bottom:10px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;flex-wrap:wrap;gap:4px;">
      <div style="font-size:12px;font-weight:700;color:#c090f0;">🗂 ${title}</div>
      <div style="display:flex;gap:6px;align-items:center;">
        ${totRef?`<span style="font-size:10px;color:#7a60a0;">Réf: ${fmtMins(totRef)}</span>`:''}
        <span style="font-size:11px;font-weight:600;color:#c090f0;" id="rpf-tot-${a.id}">${totSpent?'Total passé : '+fmtMins(totSpent):'Temps à renseigner'}</span>
      </div>
    </div>
    ${rows||`<div style="font-size:11px;color:#555;padding:6px 0;">Aucune tâche archivée — ajoutez en ci-dessous ↓</div>`}
    ${addBtn}
  </div>`;
}

function saveRapportPostFabSpent(archiveId, itemId, subId, val){
  const arch=(calState.archives||[]).find(a=>a.id===archiveId);
  if(!arch)return;
  if(!arch.postFabSnapshot)arch.postFabSnapshot={title:'Temps bureau',cats:[],items:[],nextItemId:1000,nextSubId:5000};
  const item=arch.postFabSnapshot.items.find(i=>i.id===itemId);
  if(!item)return;
  if(subId===null||subId===undefined){
    item.spent=val.trim();
  }else{
    const sub=item.subs.find(s=>s.id===subId);
    if(sub)sub.spent=val.trim();
  }
  // Recalculer totaux
  let totSpent=0;
  arch.postFabSnapshot.items.forEach(i=>{
    totSpent+=parseMins(i.spent);
    (i.subs||[]).forEach(s=>{totSpent+=parseMins(s.spent);});
  });
  const totEl=document.getElementById('rpf-tot-'+archiveId);
  if(totEl)totEl.textContent=totSpent?'Total passé : '+fmtMins(totSpent):'Temps à renseigner';
  save();
}

function addRapportPostFabItem(archiveId){
  const arch=(calState.archives||[]).find(a=>a.id===archiveId);
  if(!arch)return;
  if(!arch.postFabSnapshot)arch.postFabSnapshot={title:'Temps bureau',cats:[...DEFAULT_POSTFAB_CATS],items:[],nextItemId:1000,nextSubId:5000};
  const pf=arch.postFabSnapshot;
  const nameEl=document.getElementById('rpf-new-name-'+archiveId);
  const timeEl=document.getElementById('rpf-new-time-'+archiveId);
  if(!nameEl||!nameEl.value.trim())return;
  const catId=pf.cats&&pf.cats.length>0?pf.cats[0].id:'pfc0';
  pf.items.push({id:pf.nextItemId++,name:nameEl.value.trim(),ref:timeEl?timeEl.value.trim():'',spent:'',cat:catId,done:false,subs:[]});
  nameEl.value='';if(timeEl)timeEl.value='';
  save();
  // Re-render juste la section post-fab du rapport
  const box=document.getElementById('postfab-rapport-'+archiveId);
  if(box)box.innerHTML=buildRapportPostFabHTML(arch);
}

function buildPieSVG(a){
  // Calcul des parts par catégorie
  const catMap={};
  const catsRef=a.cats||DEFAULT_CATS;
  (a.stepDetails||[]).forEach(s=>{
    const mins=s.spentMins||s.refMins||0;
    if(!mins)return;
    catMap[s.cat]=(catMap[s.cat]||0)+mins;
  });
  const total=Object.values(catMap).reduce((s,v)=>s+v,0)||1;
  const entries=Object.entries(catMap).sort((a,b)=>b[1]-a[1]);
  const size=140, cx=70, cy=70, r=55, ri=28;
  let svg=`<svg width="${size}" height="${size}" viewBox="0 0 ${size} ${size}">`;
  svg+=`<circle cx="${cx}" cy="${cy}" r="${r}" fill="#1e1e1e"/>`;
  let angle=-Math.PI/2;
  entries.forEach(([catId,mins])=>{
    const cat=catsRef.find(c=>c.id===catId)||{color:'#888',name:catId};
    const slice=(mins/total)*2*Math.PI;
    const x1=cx+r*Math.cos(angle), y1=cy+r*Math.sin(angle);
    const x2=cx+r*Math.cos(angle+slice), y2=cy+r*Math.sin(angle+slice);
    const xi1=cx+ri*Math.cos(angle), yi1=cy+ri*Math.sin(angle);
    const xi2=cx+ri*Math.cos(angle+slice), yi2=cy+ri*Math.sin(angle+slice);
    const large=slice>Math.PI?1:0;
    svg+=`<path d="M${xi1.toFixed(1)},${yi1.toFixed(1)} L${x1.toFixed(1)},${y1.toFixed(1)} A${r},${r} 0 ${large},1 ${x2.toFixed(1)},${y2.toFixed(1)} L${xi2.toFixed(1)},${yi2.toFixed(1)} A${ri},${ri} 0 ${large},0 ${xi1.toFixed(1)},${yi1.toFixed(1)}" fill="${cat.color}" stroke="#1a1a1a" stroke-width="1"/>`;
    angle+=slice;
  });
  // Centre : pct
  svg+=`<text x="${cx}" y="${cy-4}" text-anchor="middle" font-size="14" font-weight="700" fill="#e8e8e8">${a.pct}%</text>`;
  svg+=`<text x="${cx}" y="${cy+10}" text-anchor="middle" font-size="9" fill="#888">avancement</text>`;
  svg+=`</svg>`;
  // Légende
  let legend='<div style="margin-top:6px;display:flex;flex-direction:column;gap:3px;">';
  entries.forEach(([catId,mins])=>{
    const cat=catsRef.find(c=>c.id===catId)||{color:'#888',name:catId};
    const pct2=Math.round(mins/total*100);
    legend+=`<div style="display:flex;align-items:center;gap=5px;font-size:10px;color:#aaa;">
      <span style="width:10px;height:10px;border-radius:50%;background:${cat.color};display:inline-block;margin-right:5px;flex-shrink:0;"></span>
      <span style="flex:1">${cat.name}</span>
      <span style="color:#666;margin-left:6px;">${pct2}% · ${fmtMins(mins)}</span>
    </div>`;
  });
  legend+='</div>';
  return`<div style="min-width:140px;">${svg}${legend}</div>`;
}

function buildCatsTable(a, highlightTerm){
  const catsRef=a.cats||DEFAULT_CATS;
  const grouped={};
  catsRef.forEach(c=>{grouped[c.id]=[];});
  (a.stepDetails||[]).forEach(s=>{
    if(!grouped[s.cat])grouped[s.cat]=[];
    grouped[s.cat].push(s);
  });
  const hl=highlightTerm?highlightTerm.toLowerCase():'';
  let html='';
  // En-tête du tableau global
  html+=`<div style="overflow-x:auto;">
  <table style="width:100%;border-collapse:collapse;font-size:11px;min-width:340px;">
    <thead>
      <tr style="border-bottom:2px solid #333;">
        <th style="text-align:left;padding:5px 6px;color:#666;font-weight:600;">Étape</th>
        <th style="text-align:right;padding:5px 6px;color:#5DCAA5;font-weight:600;white-space:nowrap;">Réf.</th>
        <th style="text-align:right;padding:5px 6px;color:#85B7EB;font-weight:600;white-space:nowrap;">Réel</th>
        <th style="text-align:right;padding:5px 6px;color:#EF9F27;font-weight:600;white-space:nowrap;">Écart</th>
        <th style="text-align:center;padding:5px 6px;color:#666;font-weight:600;">✓</th>
      </tr>
    </thead>
    <tbody>`;
  let anyVisible=false;
  catsRef.forEach(cat=>{
    const stepsCat=(grouped[cat.id]||[]).filter(s=>{
      if(!hl)return true;
      return s.name.toLowerCase().includes(hl);
    });
    if(stepsCat.length===0)return;
    anyVisible=true;
    const catRef=stepsCat.reduce((a,s)=>a+s.refMins,0);
    const catSpent=stepsCat.reduce((a,s)=>a+s.spentMins,0);
    const catDiff=catSpent-catRef;
    const catDiffC=catDiff>0?'#F0997B':catDiff<0?'#5DCAA5':'#666';
    const catDone=stepsCat.filter(s=>s.done).length;
    // Ligne de catégorie
    html+=`<tr style="background:#1c1c1c;">
      <td colspan="5" style="padding:6px 6px 4px;">
        <div style="display:flex;align-items:center;gap:6px;">
          <span style="width:9px;height:9px;border-radius:50%;background:${cat.color};display:inline-block;flex-shrink:0;"></span>
          <span style="font-size:11px;font-weight:700;color:${cat.color};">${cat.name}</span>
          <span style="font-size:10px;color:#555;margin-left:2px;">${catDone}/${stepsCat.length} étapes</span>
          <span style="margin-left:auto;font-size:10px;color:#5DCAA5;">${fmtMins(catRef)}</span>
          ${catSpent?`<span style="font-size:10px;color:#85B7EB;">${fmtMins(catSpent)}</span>
          <span style="font-size:10px;color:${catDiffC};">${catDiff>=0?'+':''}${fmtMins(Math.abs(catDiff))}</span>`:''}
        </div>
      </td>
    </tr>`;
    // Lignes d'étapes
    stepsCat.forEach(s=>{
      const diff=s.spentMins&&s.refMins?s.spentMins-s.refMins:null;
      const diffC=diff===null?'#666':diff>0?'#F0997B':diff<0?'#5DCAA5':'#666';
      const diffTxt=diff===null?'—':(diff>=0?'+':'')+fmtMins(Math.abs(diff));
      // Surlignage du terme recherché
      let nameHtml=s.name;
      if(hl&&s.name.toLowerCase().includes(hl)){
        const idx=s.name.toLowerCase().indexOf(hl);
        nameHtml=s.name.slice(0,idx)+`<mark style="background:#1D9E7540;color:#5DCAA5;border-radius:3px;padding:0 2px;">`+s.name.slice(idx,idx+hl.length)+`</mark>`+s.name.slice(idx+hl.length);
      }
      html+=`<tr style="border-bottom:1px solid #252525;${s.done?'':'opacity:.65;'}">
        <td style="padding:4px 6px 4px 18px;color:${s.done?'#e0e0e0':'#888'};${s.done?'':'text-decoration:line-through;'}">${nameHtml}</td>
        <td style="text-align:right;padding:4px 6px;color:#5DCAA5;white-space:nowrap;">${s.ref||'—'}</td>
        <td style="text-align:right;padding:4px 6px;color:#85B7EB;white-space:nowrap;">${s.spentMins?fmtMins(s.spentMins):'—'}</td>
        <td style="text-align:right;padding:4px 6px;color:${diffC};white-space:nowrap;font-weight:${diff&&diff!==0?'600':'400'};">${diffTxt}</td>
        <td style="text-align:center;padding:4px 6px;">
          <span style="display:inline-flex;align-items:center;justify-content:center;width:14px;height:14px;border-radius:3px;border:1.5px solid ${s.done?cat.color:'#444'};background:${s.done?cat.color:'transparent'};font-size:9px;color:#fff;">${s.done?'✓':''}</span>
        </td>
      </tr>`;
    });
  });
  if(!anyVisible&&hl){
    html+=`<tr><td colspan="5" style="text-align:center;color:#555;padding:20px;font-size:12px;">Aucune étape ne correspond à « ${hl} »</td></tr>`;
  }
  html+=`</tbody></table></div>`;
  return`<div class="chart-wrap" style="padding:0;overflow:hidden;">${html}</div>`;
}

