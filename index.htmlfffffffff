function delStockRow(section,id){
  const st=getStock();
  st[section]=st[section].filter(r=>r.id!==id);
  save();renderStockTable(section);renderStockAlerts();
}
function updateStockField(section,id,field,value){
  const st=getStock();
  const row=st[section].find(r=>r.id===id);
  if(!row)return;
  if(field==='qteParPoele'||field==='stock'){row[field]=Math.max(0,parseInt(value)||0);}
  else{row[field]=value;}
  save();
  // Only re-render the row for non-display-altering fields to avoid cursor jump
  if(field==='dateReception'||field==='receptionPar'){renderStockRow(section,id);}
  else{renderStockRow(section,id);renderStockAlerts();}
}

function getStockStatus(row,serieSize,seriesAvance){
  const qteSerie=row.qteParPoele*serieSize;
  const besoin=qteSerie*seriesAvance;
  if(row.stock<qteSerie)return'danger';
  if(row.stock<besoin)return'warn';
  return'ok';
}

// ── Drag & drop stock rows ──
let stockDragSrc=null,stockDragSection=null;
function initStockDrag(tbody,section){
  tbody.addEventListener('dragover',function(e){
    e.preventDefault();
    const tr=e.target.closest('tr');
    if(!tr||tr===stockDragSrc)return;
    tbody.querySelectorAll('tr').forEach(function(r){r.classList.remove('drag-over-top','drag-over-bot');});
    const rect=tr.getBoundingClientRect();
    const mid=rect.top+rect.height/2;
    tr.classList.add(e.clientY<mid?'drag-over-top':'drag-over-bot');
  });
  tbody.addEventListener('dragleave',function(){
    tbody.querySelectorAll('tr').forEach(function(r){r.classList.remove('drag-over-top','drag-over-bot');});
  });
  tbody.addEventListener('drop',function(e){
    e.preventDefault();
    tbody.querySelectorAll('tr').forEach(function(r){r.classList.remove('drag-over-top','drag-over-bot');});
    if(!stockDragSrc||stockDragSection!==section)return;
    const tr=e.target.closest('tr');
    if(!tr||tr===stockDragSrc)return;
    const st=getStock();
    const arr=st[section];
    const fromId=stockDragSrc.dataset.rowid;
    const toId=tr.dataset.rowid;
    const fi=arr.findIndex(function(r){return r.id===fromId;});
    const ti=arr.findIndex(function(r){return r.id===toId;});
    if(fi<0||ti<0)return;
    const rect=tr.getBoundingClientRect();
    const insertAfter=e.clientY>=rect.top+rect.height/2;
    const[moved]=arr.splice(fi,1);
    const newTi=arr.findIndex(function(r){return r.id===toId;});
    arr.splice(insertAfter?newTi+1:newTi,0,moved);
    save();renderStockTable(section);
  });
}

