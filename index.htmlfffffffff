.postfab-tot{background:#1a1025;border:1px solid #5a3a8a50;border-radius:9px;padding:8px 12px;margin:6px 13px 10px;display:flex;flex-wrap:wrap;gap:8px;align-items:center;}

.cal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;flex-wrap:wrap;gap:6px;}
.cal-month-nav{display:flex;align-items:center;gap:8px;}
.cal-nav-btn{width:30px;height:30px;border:1px solid #444;border-radius:8px;background:#2a2a2a;color:#e8e8e8;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;}
.cal-nav-btn:hover{background:#333;}
.cal-month-lbl{font-size:15px;font-weight:700;color:#e8e8e8;min-width:160px;text-align:center;}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;}
.cal-dow{font-size:10px;font-weight:600;color:#555;text-align:center;padding:4px 0;}
.cal-day{min-height:56px;background:#222;border:1px solid #2a2a2a;border-radius:6px;padding:3px;cursor:pointer;transition:border-color .15s;}
.cal-day:hover{border-color:#444;}
.cal-day.today{border-color:#1D9E75!important;}
.cal-day.weekend{background:#1c1c1c;opacity:.6;}
.cal-day.other-month{opacity:.3;}
.cal-day.hf-day{background:#2a1a00;border-color:#8a4000;}
.cal-day-num{font-size:11px;color:#666;font-weight:600;}
.cal-day.today .cal-day-num{color:#1D9E75;}
.cal-event{font-size:9px;padding:1px 4px;border-radius:3px;margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.cal-event-fab{background:#0a2a1e;color:#5DCAA5;border-left:2px solid #1D9E75;}
.cal-event-deadline{background:#2a0a0a;color:#F0997B;border-left:2px solid #E24B4A;font-weight:600;}
.cal-event-deadline-prev{background:#1a1500;color:#EF9F27;border-left:2px solid #EF9F27;}
.cal-event-hf{background:#2a1500;color:#EF9F27;}
.cal-event-today-fab{background:#0F6E56;color:#fff;font-weight:600;}
.cal-legend{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px;}
.cal-legend-item{display:flex;align-items:center;gap:4px;font-size:10px;color:#888;}
.cal-legend-dot{width:10px;height:10px;border-radius:2px;}
.deadline-config{background:#222;border:1px solid #444;border-radius:10px;padding:12px 14px;margin:0 10px 8px;}
.deadline-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:6px;}
