  tr.innerHTML=`
    <td class="stock-td" style="width:24px;"><span class="stock-drag-handle" title="Déplacer">⠿</span></td>
    <td class="stock-td"><input class="stock-inp stock-inp-name" id="snom-${row.id}" value="${row.nom.replace(/"/g,'&quot;')}" onchange="updateStockField('${section}','${row.id}','nom',this.value)" onblur="updateStockField('${section}','${row.id}','nom',this.value)"></td>
    <td class="stock-td"><input class="stock-inp" type="number" min="0" value="${row.qteParPoele}" style="width:60px;" onchange="updateStockField('${section}','${row.id}','qteParPoele',this.value)"></td>
    <td class="stock-td" style="text-align:center;color:#888;">${qteSerie}</td>
    <td class="stock-td"><input class="stock-inp" type="number" min="0" value="${row.stock}" style="width:70px;" onchange="updateStockField('${section}','${row.id}','stock',this.value)"></td>
    <td class="stock-td" style="text-align:center;">${badge}</td>
    <td class="stock-td">
      <input type="date" class="stock-inp" value="${dateVal}" style="width:100%;font-size:11px;padding:2px 5px;"
        title="${dateFmt||'Aucune réception enregistrée'}"
        onchange="updateStockField('${section}','${row.id}','dateReception',this.value)">
      ${dateFmt?'<div style="font-size:9px;color:#5DCAA5;text-align:center;margin-top:1px;">'+dateFmt+'</div>':''}
    </td>
    <td class="stock-td">
      <input class="stock-inp" placeholder="Prénom…" value="${parVal}" style="width:80px;font-size:11px;"
        onchange="updateStockField('${section}','${row.id}','receptionPar',this.value)"
        onblur="updateStockField('${section}','${row.id}','receptionPar',this.value)">
    </td>
    <td class="stock-td" style="text-align:center;"><button class="stock-del-btn" onclick="delStockRow('${section}','${row.id}')">🗑</button></td>
  `;
}

function renderStockTable(section){
  const st=getStock();
  const tbody=document.getElementById('stock-body-'+section);
  if(!tbody)return;
  tbody.innerHTML='';
  const s=st.serieSize;
  const colEl=document.getElementById('serie-col-'+section);
  if(colEl)colEl.textContent='Qté / série ('+s+')';
  if(st[section].length===0){
    tbody.innerHTML='<tr><td colspan="9" style="text-align:center;padding:16px;color:#444;font-size:11px;">Aucune pièce — cliquez sur + Ajouter</td></tr>';
    return;
  }
  st[section].forEach(function(row){
    const tr=document.createElement('tr');
    tr.id='str-'+row.id;
    tr.className='stock-tr';
    tr.draggable=true;
    tr.dataset.rowid=row.id;
    tr.addEventListener('dragstart',function(e){
      stockDragSrc=tr;stockDragSection=section;
      tr.classList.add('dragging');
      e.dataTransfer.effectAllowed='move';
    });
    tr.addEventListener('dragend',function(){
      tr.classList.remove('dragging');
      stockDragSrc=null;stockDragSection=null;
    });
    tbody.appendChild(tr);
    renderStockRow(section,row.id);
  });
  initStockDrag(tbody,section);
}

// ── Manual alerts ──
function addManualAlert(){
  const nom=prompt('Nom de la pièce à commander :');
  if(!nom||!nom.trim())return;
  const qteStr=prompt('Quantité à commander :','1');
  const qte=parseInt(qteStr)||1;
  const st=getStock();
  st.manualAlerts.push({id:'ma'+(Date.now()),nom:nom.trim(),qte,status:'pending',dateCmd:'',dateRecu:''});
  save();renderStockAlerts();
}
function dismissAlert(alertId){
  const st=getStock();
  st.manualAlerts=st.manualAlerts.filter(function(a){return a.id!==alertId;});
  save();renderStockAlerts();
}
function markOrdered(alertId){
  const st=getStock();
  const a=st.manualAlerts.find(function(x){return x.id===alertId;});
  if(!a)return;
  a.status='ordered';
  a.dateCmd=new Date().toISOString().slice(0,10);
  save();renderStockAlerts();
}
function markReceived(alertId,section,rowId){
  // If it's linked to a stock row, update the stock
  if(section&&rowId){
    const st=getStock();
    const row=st[section].find(function(r){return r.id===rowId;});
    // Don't auto-update stock quantity — user should update manually
  }
  dismissAlert(alertId);
  renderStockTable('pieces');renderStockTable('accessoires');renderStockTable('consommables');
}

function renderStockAlerts(){
  const st=getStock();
  const s=st.serieSize,av=st.seriesAvance;
  const wrap=document.getElementById('stock-alerts-wrap');
  const list=document.getElementById('stock-alerts-list');
  const footer=document.getElementById('stock-alerts-footer');
  if(!wrap||!list)return;

  // Auto-alerts from low stock
  const autoAlerts=[];
  [...st.pieces,...st.accessoires,...(st.consommables||[])].forEach(function(row){
    const status=getStockStatus(row,s,av);
    if(status!=='ok'){
      const qteSerie=row.qteParPoele*s;
      const besoin=qteSerie*av;
      const manque=Math.max(0,besoin-row.stock);
      autoAlerts.push({id:'auto-'+row.id,nom:row.nom,stock:row.stock,qteSerie,manque,status,isAuto:true});
    }
  });

  // Manual alerts (persist until dismissed/received)
  const manuals=st.manualAlerts||[];

  if(autoAlerts.length===0&&manuals.length===0){wrap.style.display='none';return;}
  wrap.style.display='block';
  if(footer)footer.textContent='Alerte si stock < '+av+' série(s) de '+s+' poêles';

  const rows=[];
  autoAlerts.forEach(function(a){
    const urgence=a.status==='danger'?'🚨':'⚠️';
    const color=a.status==='danger'?'#F0997B':'#EF9F27';
    rows.push(`<div class="alert-row">
      <span>${urgence}</span>
      <span style="color:${color};font-weight:600;flex:1;">${a.nom}</span>
      <span style="color:#666;font-size:11px;">stock : <b style="color:#e8e8e8;">${a.stock}</b> | 1 série : <b style="color:#e8e8e8;">${a.qteSerie}</b> | à commander : <b style="color:${color};">+${a.manque} pièces</b></span>
    </div>`);
  });
  manuals.forEach(function(a){
    const isOrdered=a.status==='ordered';
    const dateInfo=isOrdered&&a.dateCmd?`<span style="color:#7ab8e8;font-size:10px;">Commandé le ${a.dateCmd}</span>`:'';
    rows.push(`<div class="alert-row${isOrdered?' ordered':''}">
      <span>${isOrdered?'📦':'🔔'}</span>
      <span style="color:${isOrdered?'#7ab8e8':'#F0997B'};font-weight:600;flex:1;">${a.nom}</span>
      <span style="color:#888;font-size:11px;">Qté : <b style="color:#e8e8e8;">${a.qte} pièces</b></span>
      ${dateInfo}
      ${!isOrdered?`<button class="alert-btn alert-btn-order" onclick="markOrdered('${a.id}')">📋 Commandé</button>`:''}
      <button class="alert-btn alert-btn-recv" onclick="markReceived('${a.id}')">✅ Reçu</button>
      <button class="alert-btn-del" onclick="dismissAlert('${a.id}')">✕</button>
    </div>`);
  });
  list.innerHTML=rows.join('');
}

function renderStock(){
  const st=getStock();
  const inp=document.getElementById('stock-serie-size');if(inp)inp.value=st.serieSize;
  const av=document.getElementById('stock-avance');if(av)av.value=st.seriesAvance||2;
  renderStockTable('pieces');
