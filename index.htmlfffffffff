function saveLocal(){
  try{localStorage.setItem(STORE,JSON.stringify({steps,cats,statOrder,calState,nextId,nextSubId,ts:Date.now()}));}catch(e){}
}
function loadLocal(){
  try{
    const raw=localStorage.getItem(STORE);
    if(!raw)return false;
    const d=JSON.parse(raw);
    if(!d||!Array.isArray(d.steps)||d.steps.length===0)return false;
    steps=d.steps;
    if(Array.isArray(d.cats)&&d.cats.length>0)cats=d.cats;
    if(Array.isArray(d.statOrder)&&d.statOrder.length>0)statOrder=d.statOrder;
    if(d.calState&&d.calState.days){calState=d.calState;if(!calState.hfCats)calState.hfCats=[...DEFAULT_HF_CATS];if(!calState.stock)calState.stock=JSON.parse(JSON.stringify(DEFAULT_STOCK));}
    // Restaurer les compteurs d'ID pour éviter les collisions
    if(d.nextId&&d.nextId>nextId)nextId=d.nextId;
    if(d.nextSubId&&d.nextSubId>nextSubId)nextSubId=d.nextSubId;
    // Recalcul de sécurité : prendre le max des IDs existants + 1
    steps.forEach(function(s){
      if(s.id>=nextId)nextId=s.id+1;
      (s.subs||[]).forEach(function(sub){if(sub.id>=nextSubId)nextSubId=sub.id+1;});
    });
    return true;
  }catch(e){return false;}
}

