function confirmReset(){
  // Déduire une série du stock
  const st=getStock();
  const s=st.serieSize||10;
  let deducted=false;
  [...st.pieces,...st.accessoires].forEach(function(row){
    const qte=row.qteParPoele*s;
    if(qte>0){row.stock=Math.max(0,row.stock-qte);deducted=true;}
  });
  if(deducted){
    ss('ok','Stock mis à jour — 1 série de '+s+' déduite');
  }
  steps.forEach(s=>{s.done=false;s.spent='';s.subs.forEach(x=>x.done=false);});
  calState.days={};
  calState.horsForge={};
  calState.customDays={};
  calState.startDate='';
  const sd=document.getElementById('start-date');if(sd)sd.value='';
  const di=document.getElementById('date-info');if(di)di.textContent='';
