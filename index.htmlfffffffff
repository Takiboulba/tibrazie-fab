    const end=new Date(start);end.setDate(end.getDate()+6);
    document.getElementById('wlbl').textContent=start.toLocaleDateString('fr-FR',{day:'numeric',month:'short'})+' – '+end.toLocaleDateString('fr-FR',{day:'numeric',month:'short',year:'numeric'});
    planning.forEach((_,i)=>{const d=dayDate(i);if(d>=start&&d<=end)daysToShow.push(i);});
    // Journées custom dans la semaine
    Object.keys(calState.customDays||{}).forEach(key=>{
      const cd=calState.customDays[key];if(!cd.date)return;
      const d=new Date(cd.date+'T00:00:00');
      if(d>=start&&d<=end&&!daysToShow.includes('custom_'+key))daysToShow.push('custom_'+key);
    });
    if(daysToShow.length===0){wrap.innerHTML='<div style="text-align:center;color:#555;padding:30px;font-size:13px">Aucun jour de fabrication cette semaine</div>';}
  }else{
    daysToShow=planning.map((_,i)=>i);
    Object.keys(calState.customDays||{}).forEach(key=>daysToShow.push('custom_'+key));
  }

  daysToShow.forEach(di=>{
    if(typeof di==='string'&&di.startsWith('custom_')){
      renderCustomDay(di.replace('custom_',''),wrap);return;
    }
    const day=planning[di];const ds=getCalDay(di);
    const date=dayDate(di);const today=isToday(date);const past=isPast(date)&&!today;
    const refM=day.reduce((a,e)=>a+e.allocMins,0);
    const spentM=day.reduce((a,e)=>a+(parseMins(ds.spent[e.stepId])||0),0);
    // Utiliser steps.done pour la progression (liaison directe)
    const doneCnt=day.filter(e=>{const s=steps.find(x=>x.id===e.stepId);return s&&s.done;}).length;
    const pct=day.length?Math.round(doneCnt/day.length*100):0;
    const pbColor=pct===100?'#1D9E75':past&&pct<100?'#E24B4A':'#BA7517';
    const diff=spentM&&refM?fmtDiff(spentM,refM):null;
    const card=document.createElement('div');
    card.className='day-card'+(today?' today':'')+(past?' past':'')+(ds._open?' open':'');
    card.dataset.di=di;
    card.innerHTML=`
    <div class="day-hdr" onclick="toggleCalDay(${di})">
      <span class="day-num">Jour ${di+1}</span>
      <span class="day-date">${fmtDateShort(date)}${today?' — Auj.':''}</span>
      <div class="dpbar-bg"><div class="dpbar-fill" style="width:${pct}%;background:${pbColor}"></div></div>
      <span class="day-pct" style="color:${pbColor}">${pct}%</span>
      <span class="day-chev">▼</span>
    </div>
    <div class="day-body">
      <div class="day-steps-wrap">
        ${day.map(e=>{
          const fabStep=steps.find(x=>x.id===e.stepId);
          const done=fabStep?fabStep.done:false;
          const spent=ds.spent[e.stepId]||'';
          const sp2=parseMins(spent);const d2=sp2?fmtDiff(sp2,e.refMins):null;
          const partL=e.partial&&e.allocMins<e.refMins?`<span class="ptb ptb-part">partiel ${fmtMins(e.allocMins)}/${fmtMins(e.refMins)}</span>`:'';
          return`<div class="plan-step-row">
            <div class="pstep-chk${done?' on':''}" onclick="togglePlanStep(${e.stepId})"><svg width="9" height="9" viewBox="0 0 12 12" fill="none"><polyline points="1.5,6 4.5,9 10.5,3" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
            <div class="pstep-info">
              <div class="pstep-name${done?' done':''}">${e.name}</div>
              <div class="pstep-times">
                <span class="ptb ptb-r">⏱ ${e.ref}</span>
                <span class="ptb ptb-s${spent?' has':''}" onclick="openSpent(${di},${e.stepId},'${e.name.replace(/'/g,"\\'")}')">${spent?'⏱ '+spent:'+ temps réel'}</span>
                ${partL}${d2?`<span class="ptb" style="background:#1a1a2a;border:1px solid #333;color:${d2.pos?'#F0997B':d2.neg?'#5DCAA5':'#888'}">${d2.txt}</span>`:''}
              </div>
            </div>
          </div>`;
        }).join('')}
      </div>
      <div class="day-times-row">
        <div class="dtime-item"><div class="dtime-l">Prévu</div><div class="dtime-v" style="color:#5DCAA5">${fmtMins(refM)}</div></div>
        <div class="dtime-item"><div class="dtime-l">Passé</div><div class="dtime-v" style="color:#85B7EB">${spentM?fmtMins(spentM):'—'}</div></div>
        <div class="dtime-item"><div class="dtime-l">Écart</div><div class="dtime-v" style="color:${diff&&diff.pos?'#F0997B':diff&&diff.neg?'#5DCAA5':'#888'}">${diff?diff.txt:'—'}</div></div>
      </div>
      <div class="day-notes-wrap">
        <div class="dnotes-lbl">Notes du jour</div>
        <textarea rows="2" placeholder="Observations..." onchange="saveNote(${di},this.value)" onblur="saveNote(${di},this.value)">${ds.notes||''}</textarea>
      </div>
    </div>`;
    wrap.appendChild(card);
  });

  // Bouton ajouter journée custom
  const addBtn=document.createElement('div');
  addBtn.style.cssText='padding:4px 0;text-align:center;';
  addBtn.innerHTML=`<button class="btn btn-p" onclick="document.getElementById('modal-custom-day').classList.add('open')">+ Journée personnalisée (bureau, admin...)</button>`;
  wrap.appendChild(addBtn);
}

