function getStock(){
  if(!calState.stock){calState.stock=JSON.parse(JSON.stringify(DEFAULT_STOCK));}
  if(!calState.stock.pieces)calState.stock.pieces=[];
  if(!calState.stock.accessoires)calState.stock.accessoires=[];
  if(!calState.stock.consommables)calState.stock.consommables=[];
  if(!calState.stock.serieSize)calState.stock.serieSize=10;
  if(!calState.stock.seriesAvance)calState.stock.seriesAvance=2;
  if(!calState.stock.manualAlerts)calState.stock.manualAlerts=[];
  return calState.stock;
}

